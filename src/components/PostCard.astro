---
import type { Post } from '@/utils/post';
import { formatDate } from '@/utils/post';
import { SITE_CONFIG } from '@/config';

interface Props {
  post: Post;
  index?: number;
}
const { post, index = 0 } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const cat = SITE_CONFIG.categories[category];

// `MAY 5, 2026` style mono date
const dateMono = new Date(pubDate).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
}).toUpperCase();

const delay = `${index * 80}ms`;
---

<article class="row" data-reveal style={`--reveal-delay: ${delay};`}>
  <a class="row__link" href={`/blog/${post.slug}`} aria-label={title} data-row-link></a>

  <!-- Decorative Corners -->
  <svg class="row__corner row__corner--tl" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor"><path d="M0,12 L0,0 L12,0" stroke-width="1.5"/></svg>
  <svg class="row__corner row__corner--tr" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor"><path d="M0,0 L12,0 L12,12" stroke-width="1.5"/></svg>
  <svg class="row__corner row__corner--bl" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor"><path d="M0,0 L0,12 L12,12" stroke-width="1.5"/></svg>
  <svg class="row__corner row__corner--br" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor"><path d="M12,0 L12,12 L0,12" stroke-width="1.5"/></svg>

  <div class="row__date">
    <span class="row__date-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
        <circle cx="12" cy="15" r="1"></circle>
      </svg>
    </span>
    <span class="row__date-mono">{dateMono}</span>
  </div>

  <div class="row__body">
    <h3 class="row__title" data-text={title}>{title}</h3>
    <p class="row__desc">{description}</p>

    <div class="row__meta">
      <a class="row__cat" href={`/category/${category}`}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
        </svg>
        [ {cat.displayName.toUpperCase()} · {cat.name.toUpperCase()} ]
      </a>
      {tags && tags.length > 0 && (
        <span class="row__tags">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
          {tags.slice(0, 3).map(t => <span class="row__tag">#{t}</span>)}
        </span>
      )}
    </div>
  </div>

  <div class="row__cta">
    <span class="pill">READ <span class="arrow">↗</span></span>
  </div>
</article>

<style>
  .row {
    --mx: 50%;
    --my: 50%;
    position: relative;
    display: grid;
    grid-template-columns: 160px 1fr auto;
    align-items: start;
    gap: 2.4rem;
    padding: 1.85rem 0;
    border-top: 1px solid var(--border);
    transition: background-color var(--dur) var(--ease-soft), transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
    cursor: pointer;
  }

  .row:last-child { border-bottom: 1px solid var(--border); }

  /* Invisible full-row click target — sits ABOVE non-interactive children
     so the entire row reliably navigates to the article. Inner anchors
     (category, tags) get a higher z-index to remain individually clickable. */
  .row__link {
    position: absolute;
    inset: 0;
    z-index: 3;
    text-indent: -9999px;
    overflow: hidden;
    background: transparent;
  }

  .row__date,
  .row__body,
  .row__cta { position: relative; z-index: 1; }

  /* Inner interactive elements that should win over the overlay link */
  .row__cat { position: relative; z-index: 4; display: inline-block; }

  .row::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(800px circle at var(--mx) var(--my), rgba(255, 255, 255, 0.04), transparent 40%),
      linear-gradient(180deg, transparent, rgba(190, 210, 255, 0.03) 50%, transparent);
    background-size: 100% 100%, 100% 200%;
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    pointer-events: none;
    z-index: 0;
  }

  .row::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    background: radial-gradient(800px circle at var(--mx) var(--my), rgba(190, 210, 255, 0.6), transparent 40%) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    pointer-events: none;
    z-index: 5;
  }

  .row:hover {
    transform: translateX(10px);
    border-color: transparent;
    z-index: 10;
  }

  .row:hover::before { 
    opacity: 1; 
    animation: scanRow 2s linear infinite;
  }
  .row:hover::after { opacity: 1; }
  
  @keyframes scanRow {
    0% { background-position: 0 0, 0 -100%; }
    100% { background-position: 0 0, 0 200%; }
  }
  .row:hover .row__title { color: #fff; }
  .row:hover .pill {
    border-color: var(--border-bright);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 28px -10px rgba(190, 210, 255, 0.30), 0 0 0 1px rgba(255, 255, 255, 0.1) inset;
    transform: scale(1.05);
  }
  .row:hover .pill .arrow { transform: translate(2px, -2px); }

  /* Date column */
  .row__date {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: 0.4rem;
    color: var(--text-muted);
    transition: transform var(--dur) var(--ease-soft), color var(--dur) var(--ease-soft);
  }
  .row:hover .row__date {
    color: var(--text-dim);
  }
  .row__date-icon {
    display: inline-flex;
    color: var(--text-faint);
    transition: color var(--dur) var(--ease-soft), transform var(--dur) var(--ease-soft);
  }
  .row:hover .row__date-icon {
    color: var(--beam-cool);
    transform: scale(1.1);
  }
  .row__date-mono {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* Body */
  .row__body { display: flex; flex-direction: column; gap: 0.5rem; transition: transform var(--dur) var(--ease-soft); }
  
  .row:hover .row__body {
    transform: translateX(15px);
  }

  .row__title {
    position: relative;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.4vw, 1.4rem);
    font-weight: 400;
    color: var(--text-soft);
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color var(--dur) var(--ease-soft);
  }

  .row__title::before,
  .row__title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
  }

  .row:hover .row__title::before {
    opacity: 1;
    color: var(--beam-cool);
    z-index: -1;
    animation: glitchSlice 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }
  
  .row:hover .row__title::after {
    opacity: 1;
    color: var(--beam-warm);
    z-index: -2;
    animation: glitchSlice2 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes glitchSlice {
    0% { clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%); transform: translate(-20px, -2px); }
    100% { clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%); transform: translate(0, 0); }
  }
  @keyframes glitchSlice2 {
    0% { clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%); transform: translate(20px, 2px); }
    100% { clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%); transform: translate(0, 0); }
  }

  .row__desc {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .row__meta {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .row__cat {
    color: var(--text-muted);
    transition: color var(--dur-fast) var(--ease-soft);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .row__cat svg { opacity: 0.5; transition: opacity var(--dur) var(--ease-soft); }
  .row__cat:hover { color: var(--text); }
  .row__cat:hover svg { opacity: 1; color: var(--beam-cool); }

  .row__tags {
    display: flex;
    gap: 0.8rem;
    color: var(--text-faint);
    align-items: center;
  }
  .row__tags svg { opacity: 0.4; }
  .row__tag { transition: color var(--dur-fast) var(--ease-soft); }
  .row__tag:hover { color: var(--text-soft); }

  /* Decorative corners */
  .row__corner {
    position: absolute;
    color: var(--border-strong);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft), transform var(--dur) var(--ease-soft), color var(--dur) var(--ease-soft);
    pointer-events: none;
    z-index: 10;
  }
  .row__corner--tl { top: -6px; left: -10px; transform: translate(4px, 4px); }
  .row__corner--tr { top: -6px; right: -10px; transform: translate(-4px, 4px); }
  .row__corner--bl { bottom: -6px; left: -10px; transform: translate(4px, -4px); }
  .row__corner--br { bottom: -6px; right: -10px; transform: translate(-4px, -4px); }

  .row:hover .row__corner {
    opacity: 1;
    color: var(--beam-cool);
    transform: translate(0, 0);
  }

  /* CTA — pill aligned to right */
  .row__cta {
    align-self: center;
    pointer-events: none;
  }
  .row__cta .pill {
    pointer-events: none;
    color: var(--text);
  }

  @media (max-width: 760px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
      padding: 1.4rem 0;
    }
    .row__date { padding-top: 0; }
    .row__cta { display: none; }
  }
</style>

<script>
  function initRowHover() {
    if (window.matchMedia('(max-width: 720px)').matches) return;
    document.querySelectorAll<HTMLElement>('.row').forEach(row => {
      if ((row as any).__hoverTrack) return;
      (row as any).__hoverTrack = true;
      row.addEventListener('mousemove', (e) => {
        const r = row.getBoundingClientRect();
        row.style.setProperty('--mx', `${e.clientX - r.left}px`);
        row.style.setProperty('--my', `${e.clientY - r.top}px`);
      });
    });
  }
  initRowHover();
  document.addEventListener('astro:page-load', initRowHover);
</script>
