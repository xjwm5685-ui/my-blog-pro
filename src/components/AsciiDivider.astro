---
/**
 * AsciiDivider — animated horizontal band of mono characters that
 * randomly resolve. Sits between major sections.
 *
 * Props:
 *   density: number   length of the strip (default 64)
 *   speed:   ms per cycle (default 90)
 *   id:      stable id for resume
 */
interface Props {
  density?: number;
  speed?: number;
  id?: string;
}
const {
  density = 84,
  speed = 90,
  id = `ad-${Math.random().toString(36).slice(2, 8)}`
} = Astro.props;

// Pre-fill with a static glyph so SSR isn't blank
const seed = '·';
const initial = seed.repeat(density);
---
<div class="ad" data-density={density} data-speed={speed} id={id} aria-hidden="true">
  <div class="ad__track">
    <span class="ad__edge ad__edge--l">┤</span>
    <span class="ad__strip" data-ad-strip>{initial}</span>
    <span class="ad__edge ad__edge--r">├</span>
  </div>
</div>

<style>
  .ad {
    position: relative;
    width: 100%;
    padding: 1.2rem var(--shell-px);
    overflow: hidden;
    border-block: 1px solid var(--border);
    background: linear-gradient(180deg, transparent, rgba(190, 210, 255, 0.02), transparent);
  }
  .ad__track {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    transition: transform var(--dur) var(--ease-soft);
  }
  .ad:hover .ad__track {
    transform: scale(1.02);
  }
  .ad::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--bg) 0%, transparent 20%, transparent 80%, var(--bg) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .ad__edge {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.32em;
    transition: color var(--dur) var(--ease-soft);
  }
  .ad__strip {
    flex: 1;
    overflow: hidden;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    text-shadow: 0 0 8px rgba(190, 210, 255, 0.18);
    user-select: none;
    transition: color var(--dur) var(--ease-soft), text-shadow var(--dur) var(--ease-soft);
  }
  .ad:hover .ad__edge,
  .ad:hover .ad__strip {
    color: var(--beam-cool);
  }
  .ad:hover .ad__strip {
    color: var(--beam-cool);
    text-shadow: 0 0 10px rgba(190, 210, 255, 0.4);
    animation: pulseGlow 2s ease-in-out infinite alternate;
  }
  @keyframes pulseGlow {
    0% { text-shadow: 0 0 10px rgba(190, 210, 255, 0.4); }
    100% { text-shadow: 0 0 20px rgba(190, 210, 255, 0.8), 0 0 5px #fff; }
  }
  @media (max-width: 720px) {
    .ad { padding-block: 0.8rem; }
    .ad__strip { font-size: 0.68rem; letter-spacing: 0.12em; }
  }
</style>

<script>
  const GLYPHS = '╌─·•◦∙—-=+/\\<>[](){}╳╱╲╴╶╵╷ ';

  function bootDividers() {
    document.querySelectorAll<HTMLElement>('.ad').forEach((root) => {
      if ((root as any).__ad) return;
      (root as any).__ad = true;
      const strip = root.querySelector<HTMLElement>('[data-ad-strip]');
      if (!strip) return;
      const density = Number(root.dataset.density || 60);
      const baseSpeed = Number(root.dataset.speed || 90);
      let chars: string[] = new Array(density).fill('·');

      let lastTime = performance.now();
      let accumulator = 0;
      let rafId: number;
      let visible = false;
      let lastScrollY = window.scrollY;

      const tick = (time: number) => {
        if (!visible) return;
        
        const delta = time - lastTime;
        lastTime = time;
        
        // Calculate scroll velocity
        const currentScrollY = window.scrollY;
        const scrollDelta = Math.abs(currentScrollY - lastScrollY);
        lastScrollY = currentScrollY;
        
        // Dynamic speed based on scroll (faster scroll = smaller interval)
        const scrollBoost = Math.min(scrollDelta * 2, 80);
        const currentSpeed = Math.max(16, baseSpeed - scrollBoost);
        
        accumulator += delta;
        
        if (accumulator > currentSpeed) {
          accumulator = 0;
          // mutate chars
          // more mutation if scrolling fast
          const mutationRatio = 0.12 + (scrollBoost / 80) * 0.4;
          const n = Math.max(1, Math.floor(density * mutationRatio));
          for (let i = 0; i < n; i++) {
            const idx = Math.floor(Math.random() * density);
            chars[idx] = GLYPHS.charAt(Math.floor(Math.random() * GLYPHS.length));
          }
          strip.textContent = chars.join('');
        }
        
        rafId = requestAnimationFrame(tick);
      };

      const start = () => {
        if (visible) return;
        visible = true;
        lastTime = performance.now();
        lastScrollY = window.scrollY;
        rafId = requestAnimationFrame(tick);
      };
      
      const stop  = () => {
        visible = false;
        if (rafId) cancelAnimationFrame(rafId);
      };

      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            start();
          } else {
            stop();
          }
        }
      }, { threshold: 0.05 });
      io.observe(root);

      document.addEventListener('astro:before-swap', () => { stop(); io.disconnect(); }, { once: true });
    });
  }
  bootDividers();
  document.addEventListener('astro:page-load', bootDividers);
</script>
