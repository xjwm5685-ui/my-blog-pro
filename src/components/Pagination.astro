---
interface Props {
  prev?: { title: string; url: string };
  next?: { title: string; url: string };
}
const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="pg" aria-label="Article navigation">
    {prev ? (
      <a href={prev.url} class="pg__link pg__link--prev">
        <span class="pg__corner pg__corner--tl"></span>
        <span class="pg__corner pg__corner--bl"></span>
        <span class="pg__arrow" aria-hidden="true">←</span>
        <span class="pg__copy">
          <span class="bracket-label">PREVIOUS</span>
          <span class="pg__title">{prev.title}</span>
        </span>
      </a>
    ) : <span></span>}

    {next ? (
      <a href={next.url} class="pg__link pg__link--next">
        <span class="pg__corner pg__corner--tr"></span>
        <span class="pg__corner pg__corner--br"></span>
        <span class="pg__copy">
          <span class="bracket-label">NEXT</span>
          <span class="pg__title">{next.title}</span>
        </span>
        <span class="pg__arrow" aria-hidden="true">→</span>
      </a>
    ) : <span></span>}
  </nav>
)}

<style>
  .pg {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: var(--s-10);
    padding-top: var(--s-8);
    border-top: 1px solid var(--border);
  }

  .pg__link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-soft);
    transition:
      border-color var(--dur) var(--ease-soft),
      background var(--dur) var(--ease-soft),
      transform var(--dur) var(--ease-soft);
    overflow: hidden;
    isolation: isolate;
  }
  .pg__link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, rgba(255,255,255,0.04), transparent 60%);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    z-index: 0;
  }
  .pg__link > * { position: relative; z-index: 1; }

  .pg__link:hover {
    border-color: var(--border-strong);
    background: var(--bg-hover);
    transform: translateY(-2px);
    color: var(--text);
  }
  .pg__link:hover::before { opacity: 1; }

  .pg__link--next {
    text-align: right;
    flex-direction: row;
  }

  .pg__link--prev .pg__copy { align-items: flex-start; }
  .pg__link--next .pg__copy { align-items: flex-end; }

  .pg__copy {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-width: 0;
  }

  .pg__title {
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .pg__arrow {
    font-family: var(--font-mono);
    color: var(--text-dim);
    font-size: 1.1rem;
    transition: transform var(--dur) var(--ease-soft), color var(--dur) var(--ease-soft);
  }
  .pg__link:hover .pg__arrow { color: var(--text); }
  .pg__link--prev:hover .pg__arrow { transform: translateX(-3px); }
  .pg__link--next:hover .pg__arrow { transform: translateX(3px); }

  .pg__corner {
    position: absolute;
    width: 8px;
    height: 8px;
    border: 0 solid var(--text);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
  }
  .pg__corner--tl { top: 5px; left: 5px;  border-top-width: 1px; border-left-width: 1px; }
  .pg__corner--bl { bottom: 5px; left: 5px;  border-bottom-width: 1px; border-left-width: 1px; }
  .pg__corner--tr { top: 5px; right: 5px;  border-top-width: 1px; border-right-width: 1px; }
  .pg__corner--br { bottom: 5px; right: 5px;  border-bottom-width: 1px; border-right-width: 1px; }
  .pg__link:hover .pg__corner { opacity: 0.5; }

  @media (max-width: 720px) {
    .pg { grid-template-columns: 1fr; }
    .pg__link--next { text-align: left; flex-direction: row-reverse; }
    .pg__link--next .pg__copy { align-items: flex-start; }
  }
</style>
