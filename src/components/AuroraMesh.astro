---
/**
 * AuroraMesh — restrained liquid fluid behind the hero.
 * Three soft blue-white blobs at heavy blur drift slowly. An SVG
 * feTurbulence + feDisplacementMap filter gives them an organic
 * liquid wobble that subtly evolves over time.
 *
 * Tuned for "克制" — no saturated colors, low opacity, slow motion.
 */
---
<div class="aurora" aria-hidden="true">
  <svg class="aurora__defs" aria-hidden="true">
    <defs>
      <filter id="aurora-liquid" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.012 0.018"
          numOctaves="2"
          seed="3"
          result="noise"
        >
          <animate
            attributeName="baseFrequency"
            dur="38s"
            values="0.012 0.018;0.018 0.014;0.010 0.020;0.012 0.018"
            repeatCount="indefinite"
          />
        </feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="32" />
      </filter>
    </defs>
  </svg>

  <div class="aurora__field">
    <span class="aurora__blob aurora__blob--a"></span>
    <span class="aurora__blob aurora__blob--b"></span>
    <span class="aurora__blob aurora__blob--c"></span>
  </div>
</div>

<style>
  .aurora {
    position: absolute;
    inset: -10%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .aurora__defs {
    position: absolute;
    width: 0; height: 0;
  }

  .aurora__field {
    position: absolute;
    inset: 0;
    filter: url(#aurora-liquid) blur(40px);
    -webkit-filter: blur(80px);   /* Safari fallback — no displacement, just blur */
    opacity: 0.65;
    mix-blend-mode: screen;
    will-change: filter;
  }
  /* Browsers without SVG filter support get the blur fallback */
  @supports not (filter: url(#aurora-liquid)) {
    .aurora__field { filter: blur(90px); }
  }

  .aurora__blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  /* Three blobs — cool palette only (white-blue / soft cyan), restrained */
  .aurora__blob--a {
    width: 70vw; height: 70vw;
    top: -8%; left: -12%;
    background: radial-gradient(circle at 50% 50%,
      rgba(180, 210, 255, 0.55) 0%,
      rgba(120, 150, 220, 0.18) 45%,
      transparent 70%);
    animation: blobDriftA 56s ease-in-out infinite;
  }
  .aurora__blob--b {
    width: 60vw; height: 60vw;
    top: 35%; left: 55%;
    background: radial-gradient(circle at 50% 50%,
      rgba(220, 235, 255, 0.50) 0%,
      rgba(150, 180, 230, 0.14) 45%,
      transparent 70%);
    animation: blobDriftB 64s ease-in-out infinite reverse;
  }
  .aurora__blob--c {
    width: 50vw; height: 50vw;
    top: 50%; left: 8%;
    background: radial-gradient(circle at 50% 50%,
      rgba(160, 200, 240, 0.42) 0%,
      rgba(90, 130, 200, 0.12) 45%,
      transparent 70%);
    animation: blobDriftC 78s ease-in-out infinite;
  }

  @keyframes blobDriftA {
    0%, 100% { transform: translate(0, 0)             scale(1); }
    50%      { transform: translate(6vw, 8vh)         scale(1.08); }
  }
  @keyframes blobDriftB {
    0%, 100% { transform: translate(0, 0)             scale(1); }
    50%      { transform: translate(-9vw, -6vh)       scale(1.10); }
  }
  @keyframes blobDriftC {
    0%, 100% { transform: translate(0, 0)             scale(1); }
    50%      { transform: translate(7vw, -5vh)        scale(0.95); }
  }

  @media (max-width: 720px) {
    .aurora__field {
      filter: blur(70px);
      opacity: 0.5;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .aurora__blob,
    .aurora__defs animate { animation: none !important; }
  }
</style>
