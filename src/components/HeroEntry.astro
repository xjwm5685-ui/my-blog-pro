---
/**
 * HeroEntry — a one-shot dramatic page-load sequence.
 *
 * Fires once on the very first paint and then hides itself:
 *   1. Black plate sits over the entire viewport (z-index above hero)
 *   2. A diagonal luminous beam SWEEPS across in 1.1s
 *   3. As it sweeps, the black plate tears apart from the seam,
 *      revealing the hero underneath
 *   4. Tiny tracker text "[ INITIATING WYHEF · YYYY ]" types in the
 *      seam, then scatters
 *
 * Re-fires on each Astro view-transition (page nav).
 */
---
<div class="he" data-he aria-hidden="true">
  <span class="he__plate he__plate--top"></span>
  <span class="he__plate he__plate--bot"></span>
  <span class="he__beam"></span>
  <span class="he__sparks">
    {Array.from({ length: 14 }).map((_, i) => (
      <span class="he__spark" style={`--si: ${i};`}></span>
    ))}
  </span>
  <span class="he__hud">
    <span class="he__hud-bracket">[</span>
    <span class="he__hud-text" data-he-text>INITIATING WYHEF</span>
    <span class="he__hud-bracket">]</span>
  </span>
</div>

<style>
  .he {
    position: fixed;
    inset: 0;
    z-index: 7500;
    pointer-events: none;
    overflow: hidden;
  }
  .he.is-done { display: none; }

  .he__plate {
    position: absolute;
    left: 0; right: 0;
    height: 50%;
    background: #000;
    transform-origin: center;
  }
  .he__plate--top {
    top: 0;
    transform-origin: top;
    transform: translateY(0);
    animation: hePlateUp 1100ms cubic-bezier(0.86, 0, 0.07, 1) 320ms forwards;
  }
  .he__plate--bot {
    bottom: 0;
    transform-origin: bottom;
    transform: translateY(0);
    animation: hePlateDown 1100ms cubic-bezier(0.86, 0, 0.07, 1) 320ms forwards;
  }
  @keyframes hePlateUp   { to { transform: translateY(-100%); } }
  @keyframes hePlateDown { to { transform: translateY( 100%); } }

  .he__beam {
    position: absolute;
    top: 50%;
    left: -25vw;
    width: 25vw;
    height: 6px;
    transform: translateY(-50%) skewX(-22deg);
    background: linear-gradient(90deg,
      transparent,
      rgba(190, 210, 255, 0.95) 30%,
      rgba(255, 255, 255, 1) 50%,
      rgba(190, 210, 255, 0.95) 70%,
      transparent);
    box-shadow:
      0 0 30px rgba(255, 255, 255, 0.95),
      0 0 80px rgba(190, 210, 255, 0.85);
    animation: heBeamSweep 1300ms cubic-bezier(0.86, 0, 0.07, 1) 200ms forwards;
  }
  @keyframes heBeamSweep {
    0%   { left: -25vw; opacity: 0; }
    8%   { opacity: 1; }
    50%  { height: 14px; }
    92%  { opacity: 1; }
    100% { left: 110vw; opacity: 0; height: 4px; }
  }

  .he__sparks {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .he__spark {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3px; height: 3px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.95), 0 0 20px rgba(190, 210, 255, 0.6);
    transform-origin: 0 0;
    transform: translate(-50%, -50%) rotate(calc(var(--si) * 25.7deg)) translateX(0);
    opacity: 0;
    animation: heSpark 900ms cubic-bezier(0.16, 1, 0.3, 1) 750ms forwards;
  }
  @keyframes heSpark {
    0%   { transform: translate(-50%, -50%) rotate(calc(var(--si) * 25.7deg)) translateX(0);    opacity: 1; }
    100% { transform: translate(-50%, -50%) rotate(calc(var(--si) * 25.7deg)) translateX(60vw); opacity: 0; }
  }

  .he__hud {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0;
    animation:
      heHudIn  280ms ease 280ms forwards,
      heHudOut 280ms ease 1100ms forwards;
  }
  @keyframes heHudIn  { from { opacity: 0; transform: translate(-50%, -50%) scale(0.85); } to { opacity: 1; transform: translate(-50%, -50%) scale(1); } }
  @keyframes heHudOut { from { opacity: 1; transform: translate(-50%, -50%) scale(1); }    to { opacity: 0; transform: translate(-50%, -50%) scale(1.06); } }
  .he__hud-bracket { color: var(--text-muted); }
</style>

<script>
  function bootHE() {
    const root = document.querySelector<HTMLElement>('[data-he]');
    const text = document.querySelector<HTMLElement>('[data-he-text]');
    if (!root) return;
    if (text) {
      const y = new Date().getFullYear();
      text.textContent = `INITIATING WYHEF · ${y}`;
    }
    // hide the entry plate after the animation
    window.setTimeout(() => root.classList.add('is-done'), 1700);
  }
  bootHE();
  /* re-arm on Astro view transitions so each page nav also gets the sweep
     (RouteTransition handles its own thing — this one only fires once per load) */
</script>
