---
import BaseLayout from '@layouts/BaseLayout.astro';
import Constellation from '@components/Constellation.astro';
import LightBeam from '@components/LightBeam.astro';
---

<BaseLayout title="404 — Lost in space" description="Page not found">
  <section class="four">
    <LightBeam side="right" intensity={0.6} />

    <div class="four__inner shell">
      <span class="bracket-label" data-reveal>SIGNAL · LOST</span>

      <h1 class="four__code" data-reveal style="--reveal-delay: 80ms">
        <span style="animation-delay: 80ms">4</span><span style="animation-delay: 160ms">0</span><span style="animation-delay: 240ms">4</span>
      </h1>

      <p class="four__lede" data-reveal style="--reveal-delay: 240ms">
        这片星空里没有这条路径。<br/>
        <span class="four__lede-en">The path you took drifted out of orbit.</span>
      </p>

      <div class="four__cta" data-reveal style="--reveal-delay: 320ms">
        <a href="/"     class="pill">RETURN HOME <span class="arrow">↗</span></a>
        <a href="/blog" class="pill pill--ghost">BROWSE ARCHIVE <span class="arrow">↗</span></a>
      </div>
    </div>

    <div class="four__cosmos">
      <Constellation height="48vh" density={120} minimal={true} />
    </div>
  </section>
</BaseLayout>

<style>
  .four {
    position: relative;
    min-height: calc(100vh - var(--nav-h));
    display: grid;
    grid-template-rows: 1fr auto;
    overflow: hidden;
    isolation: isolate;
  }

  .four__inner {
    position: relative;
    z-index: 5;
    align-self: center;
    padding-block: var(--s-10);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.6rem;
  }

  .four__code {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: clamp(7rem, 26vw, 22rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: var(--text);
    margin: 0;
    text-shadow:
      0 0 80px rgba(190, 210, 255, 0.18),
      0 0 160px rgba(255, 240, 220, 0.06);
  }
  .four__code span {
    display: inline-block;
    opacity: 0;
    transform: translateY(0.3em);
    filter: blur(12px);
    animation: letterRise 1100ms var(--ease-out) forwards;
  }

  .four__lede {
    color: var(--text-dim);
    font-family: var(--font-cn);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 50ch;
  }
  .four__lede-en {
    font-family: var(--font-display);
    color: var(--text-muted);
    font-size: 0.92em;
    font-style: italic;
  }

  .four__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .four__cosmos {
    position: relative;
    z-index: 1;
    margin-top: -8vh;
  }
</style>
