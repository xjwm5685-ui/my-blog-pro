---
/**
 * RouteTransition — drives a black light-band sweep when navigating
 * between pages. Hooks into Astro's view-transition events.
 *
 * Uses two horizontal blades that converge across the viewport,
 * leaving a thin luminous seam in the middle, then receding.
 */
---
<div class="rt" data-rt aria-hidden="true">
  <span class="rt__blade rt__blade--top"></span>
  <span class="rt__blade rt__blade--bot"></span>
  <span class="rt__seam"></span>
  <span class="rt__hud">
    <span class="rt__hud-bracket">[</span>
    <span class="rt__hud-text" data-rt-text>NAVIGATING</span>
    <span class="rt__hud-bracket">]</span>
  </span>
</div>

<style>
  .rt {
    position: fixed;
    inset: 0;
    z-index: 8000;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: visibility 0s linear 700ms;
  }
  .rt.is-active {
    opacity: 1;
    visibility: visible;
    transition: visibility 0s linear;
  }

  .rt__blade {
    position: absolute;
    left: 0; right: 0;
    height: 50%;
    background: #000;
    transform: scaleY(0);
    transform-origin: center;
    will-change: transform;
  }
  .rt__blade--top {
    top: 0;
    transform-origin: top;
    background: linear-gradient(180deg, #000 0%, #000 86%, rgba(190,210,255,0.4) 99%, transparent);
  }
  .rt__blade--bot {
    bottom: 0;
    transform-origin: bottom;
    background: linear-gradient(0deg, #000 0%, #000 86%, rgba(190,210,255,0.4) 99%, transparent);
  }

  .rt__seam {
    position: absolute;
    left: 0; right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg,
      transparent,
      rgba(255, 255, 255, 0.95) 50%,
      transparent);
    box-shadow: 0 0 20px rgba(190, 210, 255, 0.7);
    transform: translateY(-0.5px) scaleX(0);
    transform-origin: left;
    will-change: transform;
  }

  .rt__hud {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0;
  }
  .rt__hud-bracket { color: var(--text-muted); }

  /* the active sequence */
  .rt.is-active .rt__blade--top { animation: rtBladeIn 280ms cubic-bezier(0.86, 0, 0.07, 1) forwards; }
  .rt.is-active .rt__blade--bot { animation: rtBladeIn 280ms cubic-bezier(0.86, 0, 0.07, 1) forwards; }
  .rt.is-active .rt__seam       { animation: rtSeam    420ms ease 80ms forwards; }
  .rt.is-active .rt__hud        { animation: rtHud     420ms ease 100ms forwards; }

  .rt.is-leaving .rt__blade--top { animation: rtBladeOut 320ms cubic-bezier(0.86, 0, 0.07, 1) forwards; }
  .rt.is-leaving .rt__blade--bot { animation: rtBladeOut 320ms cubic-bezier(0.86, 0, 0.07, 1) forwards; }
  .rt.is-leaving .rt__seam       { animation: rtSeamOut 220ms ease forwards; }
  .rt.is-leaving .rt__hud        { animation: rtHudOut  180ms ease forwards; }

  @keyframes rtBladeIn  { from { transform: scaleY(0); } to { transform: scaleY(1); } }
  @keyframes rtBladeOut { from { transform: scaleY(1); } to { transform: scaleY(0); } }
  @keyframes rtSeam     { from { transform: translateY(-0.5px) scaleX(0); } to { transform: translateY(-0.5px) scaleX(1); } }
  @keyframes rtSeamOut  { from { transform: translateY(-0.5px) scaleX(1); opacity: 1; } to { transform: translateY(-0.5px) scaleX(0); opacity: 0; } }
  @keyframes rtHud      { 0% { opacity: 0; transform: translate(-50%, -50%) scale(0.95); } 60% { opacity: 1; } 100% { opacity: 1; transform: translate(-50%, -50%) scale(1); } }
  @keyframes rtHudOut   { from { opacity: 1; } to { opacity: 0; } }
</style>

<script>
  function bootRT() {
    const root = document.querySelector<HTMLElement>('[data-rt]');
    const text = document.querySelector<HTMLElement>('[data-rt-text]');
    if (!root) return;

    document.addEventListener('astro:before-preparation', (e: any) => {
      try {
        if (text) {
          const url = new URL(e.to ?? location.href, location.origin);
          const pathname = url.pathname.replace(/^\/+|\/+$/g, '') || 'home';
          text.textContent = `NAVIGATING · ${pathname.toUpperCase()}`;
        }
      } catch { /* noop */ }
      root.classList.remove('is-leaving');
      root.classList.add('is-active');
    });

    document.addEventListener('astro:after-swap', () => {
      root.classList.add('is-leaving');
      window.setTimeout(() => {
        root.classList.remove('is-active');
        root.classList.remove('is-leaving');
      }, 380);
    });
  }
  bootRT();
</script>
