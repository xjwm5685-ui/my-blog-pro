---
/**
 * Search — dual-mode client-side search.
 * Variant `hero` is the giant landing input; `compact` is the dropdown.
 *
 * Reads /search-data.json built by the existing endpoint.
 */
interface Props {
  variant?: 'hero' | 'compact';
  placeholder?: string;
}
const { variant = 'hero', placeholder = '搜索文章 · What do you want to read?' } = Astro.props;
---

<div class:list={['search', `search--${variant}`]}>
  <form class="search__form" role="search" autocomplete="off">
    <span class="search__leader" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
        <circle cx="11" cy="11" r="7"/>
        <line x1="20" y1="20" x2="16.6" y2="16.6"/>
      </svg>
    </span>
    <input
      class="search__input"
      type="search"
      placeholder={placeholder}
      aria-label="Search posts"
      data-search-input
    />
    <button class="search__btn" type="submit" aria-label="Submit search">
      <span class="arrow" aria-hidden="true">↗</span>
    </button>
  </form>

  <div class="search__panel" data-search-panel hidden>
    <div class="search__panel-head">
      <span class="bracket-label">RESULTS</span>
      <span class="search__count" data-search-count>—</span>
    </div>
    <div class="search__results" data-search-results></div>
  </div>
</div>

<style>
  .search { width: 100%; position: relative; isolation: isolate; }

  /* hero variant — large translucent capsule */
  .search--hero { max-width: 580px; }
  .search--hero .search__form {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.6rem 0.6rem 1.2rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-strong);
    border-radius: var(--r-pill);
    backdrop-filter: blur(8px);
    transition: border-color var(--dur) var(--ease-soft), background var(--dur) var(--ease-soft);
  }
  .search--hero .search__form:focus-within {
    border-color: var(--border-bright);
    background: rgba(255, 255, 255, 0.07);
    box-shadow: 0 0 0 1px var(--border) inset, 0 12px 40px -12px rgba(190, 210, 255, 0.25);
  }

  /* compact variant — used in nav or interior pages */
  .search--compact .search__form {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.85rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
  }
  .search--compact .search__btn { display: none; }

  .search__leader {
    color: var(--text-muted);
    display: inline-flex;
  }

  .search__input {
    width: 100%;
    background: transparent;
    border: 0;
    outline: 0;
    color: var(--text);
    font-family: var(--font-cn);
    font-size: 0.95rem;
  }
  .search__input::placeholder { color: var(--text-muted); }

  .search--hero .search__input { font-size: 1rem; }

  .search__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border-strong);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    cursor: pointer;
    transition:
      border-color var(--dur) var(--ease-soft),
      background var(--dur) var(--ease-soft),
      transform var(--dur) var(--ease-soft);
  }
  .search__btn:hover {
    border-color: var(--border-bright);
    background: rgba(255, 255, 255, 0.10);
    transform: translateY(-1px);
  }
  .search__btn .arrow { line-height: 1; }

  /* dropdown panel */
  .search__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    background: var(--bg-card);
    border: 1px solid var(--border-strong);
    border-radius: 14px;
    overflow: hidden;
    z-index: 60;
    box-shadow: 0 30px 70px -30px rgba(0, 0, 0, 0.85);
  }
  .search--hero .search__panel { border-radius: 22px; }

  .search__panel[hidden] { display: none; }

  .search__panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .search__count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .search__results {
    max-height: 60vh;
    overflow-y: auto;
  }

  .result {
    display: block;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-soft);
    transition: background-color var(--dur-fast) var(--ease-soft);
  }
  .result:last-child { border-bottom: 0; }
  .result:hover, .result.is-focused {
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
  }

  .result__head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }
  .result__title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    color: var(--text);
  }
  .result__meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .result__excerpt {
    color: var(--text-dim);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-top: 0.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .result__empty {
    padding: 1.5rem 1rem;
    text-align: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
</style>

<script>
  type SearchItem = {
    title: string;
    description: string;
    url: string;
    category: string;
    tags: string[];
  };

  let cache: SearchItem[] | null = null;

  async function load(): Promise<SearchItem[]> {
    if (cache) return cache;
    try {
      const r = await fetch('/search-data.json');
      cache = await r.json();
      return cache!;
    } catch {
      cache = [];
      return cache;
    }
  }

  function escape(s: string) {
    return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  function render(panel: HTMLElement, results: SearchItem[]) {
    const list = panel.querySelector<HTMLElement>('[data-search-results]')!;
    const count = panel.querySelector<HTMLElement>('[data-search-count]')!;
    if (!results.length) {
      count.textContent = '00';
      list.innerHTML = '<div class="result__empty">未找到相关文章 · NO RESULTS</div>';
      return;
    }
    count.textContent = String(results.length).padStart(2, '0');
    list.innerHTML = results.slice(0, 10).map(r => `
      <a class="result" href="${r.url}">
        <div class="result__head">
          <span class="result__title">${escape(r.title)}</span>
          <span class="result__meta">${escape(r.category)}</span>
        </div>
        <div class="result__excerpt">${escape(r.description)}</div>
      </a>
    `).join('');
  }

  function bootSearch() {
    document.querySelectorAll<HTMLElement>('.search').forEach((root) => {
      if ((root as any).__search) return;
      (root as any).__search = true;

      const input = root.querySelector<HTMLInputElement>('[data-search-input]')!;
      const panel = root.querySelector<HTMLElement>('[data-search-panel]')!;
      const form  = root.querySelector<HTMLFormElement>('form')!;
      let timer: number | undefined;

      const close = () => { panel.hidden = true; };
      const open  = () => { panel.hidden = false; };

      input.addEventListener('input', () => {
        clearTimeout(timer);
        const q = input.value.trim().toLowerCase();
        if (!q) { close(); return; }
        timer = window.setTimeout(async () => {
          const data = await load();
          const out = data.filter(it =>
            it.title.toLowerCase().includes(q) ||
            it.description.toLowerCase().includes(q) ||
            (it.tags || []).some(t => t.toLowerCase().includes(q))
          );
          render(panel, out);
          open();
        }, 160);
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const first = panel.querySelector<HTMLAnchorElement>('.result');
        if (first) location.href = first.href;
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { close(); input.blur(); }
      });

      document.addEventListener('click', (e) => {
        if (!root.contains(e.target as Node)) close();
      });
    });
  }
  bootSearch();
  document.addEventListener('astro:page-load', bootSearch);
</script>
