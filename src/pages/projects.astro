---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const projects = [
  {
    name: '星煜凡程',
    en:   'Star Goals',
    desc: '个人长期目标管理与追踪平台，记录成长轨迹。',
    tagline: 'Long-term goals · life tracker',
    url: 'https://goals.wyhef.cloud',
    github: 'https://github.com/WYHEF/long-term-goals',
    tech: ['Web', 'Full-stack', 'TypeScript']
  },
  {
    name: 'KMP 算法可视化',
    en:   'KMP Visualizer',
    desc: 'KMP 字符串匹配算法的交互式可视化演示页面。',
    tagline: 'Interactive algorithm demo',
    url: 'https://kmp.wyhef.cloud',
    github: 'https://github.com/WYHEF/kmp',
    tech: ['Algorithm', 'Visualization', 'Front-end']
  },
  {
    name: '个人博客',
    en:   'Personal Blog',
    desc: '基于 Astro 构建的静态博客，记录技术、学习和生活。',
    tagline: 'A field log · this site',
    url: 'https://www.wyhef.cloud',
    github: 'https://github.com/WYHEF/my-blog',
    tech: ['Astro', 'TypeScript', 'SSG']
  }
];
---

<BaseLayout
  title={`成品项目 · PROJECTS — ${SITE_CONFIG.title}`}
  description={`${SITE_CONFIG.author}的个人项目展示`}
>
  <div class="projects shell">
    <header class="projects__head" data-reveal>
      <span class="bracket-label">PROJECTS</span>
      <h1 class="projects__title">
        Things I've built<br/>
        <span class="projects__title-cn">独立完成的一些项目</span>
      </h1>
      <p class="projects__lede">
        每个项目都是一段学习与实践的经历 — A small atlas of side-projects, ordered by what I learnt building them.
      </p>
    </header>

    <div class="projects__grid">
      {projects.map((p, i) => (
        <article class="project" data-reveal data-tilt data-tilt-max="6" style={`--reveal-delay: ${i * 100}ms;`}>
          <div class="project__head">
            <span class="bracket-label">PROJECT · 0{i + 1}</span>
            <span class="project__lede">{p.tagline}</span>
          </div>

          <div class="project__title-row">
            <h2 class="project__name">{p.name}</h2>
            <span class="project__en">{p.en}</span>
          </div>

          <p class="project__desc">{p.desc}</p>

          <ul class="project__tech">
            {p.tech.map(t => <li>{t}</li>)}
          </ul>

          <div class="project__sketch" aria-hidden="true">
            <svg viewBox="0 0 320 80" preserveAspectRatio="none" width="100%" height="80" stroke="currentColor" fill="none" stroke-width="0.6">
              <line x1="0"   y1="40" x2="320" y2="40"/>
              <line x1="0"   y1="60" x2="320" y2="60" opacity="0.4"/>
              <line x1="0"   y1="20" x2="320" y2="20" opacity="0.4"/>
              <line x1="40"  y1="0"  x2="40"  y2="80" opacity="0.25"/>
              <line x1="120" y1="0"  x2="120" y2="80" opacity="0.25"/>
              <line x1="200" y1="0"  x2="200" y2="80" opacity="0.25"/>
              <line x1="280" y1="0"  x2="280" y2="80" opacity="0.25"/>
              <circle cx={40 + (i * 80)} cy="40" r="3" fill="currentColor"/>
            </svg>
          </div>

          <div class="project__cta">
            <a class="pill" href={p.url} target="_blank" rel="noopener">VISIT <span class="arrow">↗</span></a>
            <a class="pill pill--ghost" href={p.github} target="_blank" rel="noopener">GITHUB <span class="arrow">↗</span></a>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .projects { padding-block: var(--s-10) var(--s-14); }

  .projects__head { margin-bottom: var(--s-10); max-width: 800px; }
  .projects__title {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .projects__title-cn {
    font-family: var(--font-cn);
    color: var(--text-dim);
    font-size: 0.6em;
  }
  .projects__lede {
    margin-top: 1rem;
    color: var(--text-dim);
    font-family: var(--font-cn);
    font-size: 1rem;
    line-height: 1.65;
    max-width: 64ch;
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }
  @media (max-width: 1000px) { .projects__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px)  { .projects__grid { grid-template-columns: 1fr; } }

  .project {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.6rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition:
      border-color var(--dur) var(--ease-soft),
      background var(--dur) var(--ease-soft),
      transform var(--dur) var(--ease-soft);
  }
  .project:hover {
    border-color: var(--border-strong);
    background: var(--bg-hover);
    transform: translateY(-2px);
  }

  .project__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .project__lede {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--text-faint);
    text-transform: uppercase;
  }

  .project__title-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .project__name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.015em;
  }
  .project__en {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .project__desc {
    color: var(--text-dim);
    font-family: var(--font-cn);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .project__tech {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .project__tech li {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.18rem 0.55rem;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .project__sketch {
    color: var(--text-faint);
    margin-top: auto;
    transition: color var(--dur) var(--ease-soft);
  }
  .project:hover .project__sketch { color: var(--text-dim); }

  .project__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
