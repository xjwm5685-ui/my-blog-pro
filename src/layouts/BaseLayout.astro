---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import TableOfContents from '@components/TableOfContents.astro';
import ScrollProgress from '@components/ScrollProgress.astro';
import Cursor from '@components/Cursor.astro';
import HudLive from '@components/HudLive.astro';
import GlitchAlert from '@components/GlitchAlert.astro';
import SectionIndicator from '@components/SectionIndicator.astro';
import Spotlight from '@components/Spotlight.astro';
import Starfield from '@components/Starfield.astro';
import { ViewTransitions } from 'astro:transitions';
import '@/styles/global.css';
import { getSEO, type SEOProps } from '@/utils/seo';
import type { MarkdownHeading } from 'astro';
import { SITE_CONFIG } from '@/config';

interface Props extends SEOProps {
  class?: string;
  currentSlug?: string;
  currentCategory?: string;
  headings?: MarkdownHeading[];
}

const {
  title,
  description,
  image,
  article,
  publishedTime,
  tags,
  class: className,
  headings
} = Astro.props;

const seo = getSEO({ title, description, image, article, publishedTime, tags });
const hasTOC = headings && headings.length > 0;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />
  <meta name="theme-color" content="#000000" />

  <meta property="og:type" content={seo.openGraph.type} />
  <meta property="og:title" content={seo.openGraph.title} />
  <meta property="og:description" content={seo.openGraph.description} />
  <meta property="og:image" content={seo.openGraph.image} />

  <link rel="alternate" type="application/rss+xml" title={`${SITE_CONFIG.title} RSS`} href="/rss.xml" />
  <ViewTransitions />
</head>

<body>
  <Starfield />
  <Spotlight />
  <span class="scanlines" aria-hidden="true"></span>
  <div class="ambient-glow" data-ambient-glow aria-hidden="true"></div>
  <ScrollProgress />
  <Cursor />
  <HudLive />
  <SectionIndicator />
  <GlitchAlert />
  <Header />

  <div class="shell-grid">
    <main class:list={['main', { 'main--with-toc': hasTOC }, className]}>
      <slot />
    </main>

    {hasTOC && (
      <aside class="toc-aside" aria-label="Table of contents">
        <TableOfContents headings={headings!} />
      </aside>
    )}
  </div>

  <Footer />

  <script>
    /* ---- IntersectionObserver fade-up reveals ---- */
    function bindReveal() {
      const els = document.querySelectorAll<HTMLElement>('[data-reveal]:not(.is-visible)');
      if (!els.length || !('IntersectionObserver' in window)) {
        els.forEach(el => el.classList.add('is-visible'));
        return;
      }
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            (e.target as HTMLElement).classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
      els.forEach(el => io.observe(el));
    }

    /* ---- Magnetic pills — gentle pull toward cursor on hover ---- */
    function bindMagnetic() {
      document.querySelectorAll<HTMLElement>('.pill, .nav__cta').forEach((el) => {
        if ((el as any).__mag) return;
        (el as any).__mag = true;
        let raf = 0;
        let tx = 0, ty = 0, cx = 0, cy = 0;
        const strength = 8;

        const apply = () => {
          cx += (tx - cx) * 0.18;
          cy += (ty - cy) * 0.18;
          el.style.transform = `translate3d(${cx.toFixed(2)}px, ${cy.toFixed(2)}px, 0)`;
          if (Math.abs(tx - cx) + Math.abs(ty - cy) > 0.05) {
            raf = requestAnimationFrame(apply);
          } else {
            raf = 0;
          }
        };

        el.addEventListener('mousemove', (e) => {
          const r = el.getBoundingClientRect();
          tx = ((e.clientX - r.left) / r.width  - 0.5) * strength * 2;
          ty = ((e.clientY - r.top)  / r.height - 0.5) * strength * 2;
          el.style.setProperty('--mx', `${e.clientX - r.left}px`);
          el.style.setProperty('--my', `${e.clientY - r.top}px`);
          if (!raf) raf = requestAnimationFrame(apply);
        });
        el.addEventListener('mouseleave', () => {
          tx = 0; ty = 0;
          if (!raf) raf = requestAnimationFrame(apply);
        });
      });
    }

    /* ---- Signal Glitch Reveal on section enters ---- */
    function bindGlitchReveal() {
      const sections = document.querySelectorAll<HTMLElement>('section.block, .arc__year, .bio__section');
      if (!sections.length) return;

      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          const el = e.target as HTMLElement;
          if (e.isIntersecting) {
            el.style.transition = 'opacity 900ms var(--ease-out), transform 900ms var(--ease-out), filter 900ms var(--ease-out)';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0) scale(1)';
            el.style.filter = 'blur(0) contrast(1)';
            // Optional: add a quick glitch animation class if defined in global.css
            el.classList.add('glitch-enter');
            io.unobserve(el);
          }
        }
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.06 });

      sections.forEach((s) => {
        if (s.classList.contains('--glitch-init')) return;
        s.classList.add('--glitch-init');
        s.style.opacity = '0';
        s.style.transform = 'translateY(20px) scale(0.98)';
        s.style.filter = 'blur(10px) contrast(2)';
        io.observe(s);
      });
    }

    /* ---- Generic 2D tilt/shine for [data-tilt] elements ---- */
    function bindTilt() {
      if (window.matchMedia('(max-width: 720px)').matches) return;
      document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((el) => {
        if ((el as any).__tilt) return;
        (el as any).__tilt = true;
        let raf = 0;
        let tx = 0, ty = 0, cx = 0, cy = 0;
        const apply = () => {
          cx += (tx - cx) * 0.12;
          cy += (ty - cy) * 0.12;
          // pure 2D subtle shift instead of 3D rotate
          el.style.transform = `translate(${(cx * -4).toFixed(2)}px, ${(cy * -4).toFixed(2)}px)`;
          if (Math.abs(tx - cx) + Math.abs(ty - cy) > 0.001) {
            raf = requestAnimationFrame(apply);
          } else {
            raf = 0;
          }
        };
        el.addEventListener('mousemove', (e) => {
          const r = el.getBoundingClientRect();
          tx = ((e.clientX - r.left) / r.width)  * 2 - 1;
          ty = ((e.clientY - r.top)  / r.height) * 2 - 1;
          el.style.setProperty('--mx', `${e.clientX - r.left}px`);
          el.style.setProperty('--my', `${e.clientY - r.top}px`);
          if (!raf) raf = requestAnimationFrame(apply);
        });
        el.addEventListener('mouseleave', () => {
          tx = 0; ty = 0;
          if (!raf) raf = requestAnimationFrame(apply);
        });
      });
    }

    /* ---- Click ripple — burst on every pill / row click ---- */
    function bindRipple() {
      // Prevent multiple global listeners
      if ((window as any).__rippleBound) return;
      (window as any).__rippleBound = true;

      const SEL = '.pill, .row, .nav__link, .card__cta';
      document.addEventListener('pointerdown', (e) => {
        const t = (e.target as HTMLElement)?.closest?.(SEL) as HTMLElement | null;
        if (!t) return;
        const r = t.getBoundingClientRect();
        const x = (e as PointerEvent).clientX - r.left;
        const y = (e as PointerEvent).clientY - r.top;
        const ring = document.createElement('span');
        ring.className = 'ripple';
        ring.style.left = x + 'px';
        ring.style.top  = y + 'px';
        // make sure host is positioned + clips
        const cs = getComputedStyle(t);
        if (cs.position === 'static') t.style.position = 'relative';
        if (cs.overflow !== 'hidden')   t.style.overflow = 'hidden';
        t.appendChild(ring);
        ring.addEventListener('animationend', () => ring.remove(), { once: true });
      });
    }

    /* ---- Scroll Velocity Skew ---- */
    function bindScrollVelocity() {
      if (window.matchMedia('(max-width: 720px)').matches) return;
      const targets = document.querySelectorAll<HTMLElement>('.row, .about-card, .block__head, .cards > *');
      if (!targets.length) return;
      
      // Prevent multiple global listeners
      if ((window as any).__scrollVelBound) return;
      (window as any).__scrollVelBound = true;
      
      let raf = 0;
      let lastY = window.scrollY;
      let smoothedVel = 0;

      const tick = () => {
        const y = window.scrollY;
        const vel = y - lastY;
        lastY = y;
        
        smoothedVel += (vel - smoothedVel) * 0.12;
        
        // Clamp and apply
        const skew = Math.max(-3, Math.min(3, smoothedVel * 0.04));
        
        // Re-query targets in case of navigation
        const currentTargets = document.querySelectorAll<HTMLElement>('.row, .about-card, .block__head, .cards > *');
        currentTargets.forEach(t => {
          t.style.transform = `skewY(${skew}deg)`;
        });

        if (Math.abs(smoothedVel) > 0.1 || Math.abs(vel) > 0) {
          raf = requestAnimationFrame(tick);
        } else {
          currentTargets.forEach(t => t.style.transform = 'skewY(0deg)');
          raf = 0;
        }
      };
      
      window.addEventListener('scroll', () => {
        if (!raf) raf = requestAnimationFrame(tick);
      }, { passive: true });
    }

    function bootAll() { bindReveal(); bindMagnetic(); bindGlitchReveal(); bindTilt(); bindRipple(); bindScramble(); bindScrollVelocity(); bindAmbientGlow(); }
    bootAll();
    document.addEventListener('astro:page-load', bootAll);

    /* ---- Ambient background glow tracking mouse ---- */
    function bindAmbientGlow() {
      if (window.matchMedia('(max-width: 720px)').matches) return;
      const glow = document.querySelector<HTMLElement>('[data-ambient-glow]');
      if (!glow) return;
      
      // Prevent multiple instances
      if ((glow as any).__bound) return;
      (glow as any).__bound = true;
      
      let raf = 0;
      let mx = window.innerWidth / 2;
      let my = window.innerHeight / 2;
      let cx = mx, cy = my;

      const tick = () => {
        cx += (mx - cx) * 0.08;
        cy += (my - cy) * 0.08;
        glow.style.transform = `translate3d(${cx}px, ${cy}px, 0) translate(-50%, -50%)`;
        raf = requestAnimationFrame(tick);
      };
      raf = requestAnimationFrame(tick);

      const onMove = (e: MouseEvent) => {
        mx = e.clientX;
        my = e.clientY;
      };
      window.addEventListener('mousemove', onMove, { passive: true });
      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(raf);
        window.removeEventListener('mousemove', onMove);
      }, { once: true });
    }

    /* ---- Glitch scramble — characters cycle through random glyphs and resolve.
       Applied to .bracket-label and .nav__link-en, plus anything tagged
       data-scramble. Triggers on hover / focus / first reveal. ---- */
    function bindScramble() {
      const GLYPHS = '!@#$%&?*+=/\\-_<>{}[]ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
      const SEL = '.bracket-label, .nav__link-en, [data-scramble]';

      const scramble = (node: HTMLElement, original: string) => {
        const len = original.length;
        const total = 16;       // frames
        let frame = 0;
        const id = window.setInterval(() => {
          frame++;
          let out = '';
          for (let i = 0; i < len; i++) {
            const ch = original[i];
            if (ch === ' ' || ch === '·' || ch === '[' || ch === ']') { out += ch; continue; }
            if (frame > (total * (i / len)) + 1) {
              out += original[i];
            } else {
              out += GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
            }
          }
          node.textContent = out;
          if (frame > total) {
            window.clearInterval(id);
            node.textContent = original;
          }
        }, 28);
      };

      document.querySelectorAll<HTMLElement>(SEL).forEach((el) => {
        if ((el as any).__scram) return;
        (el as any).__scram = true;
        const original = (el.textContent || '').trim();
        if (!original) return;
        // run once on first viewport entry
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              scramble(e.target as HTMLElement, original);
              io.unobserve(e.target);
            }
          }
        }, { threshold: 0.5 });
        io.observe(el);
        // and again on hover
        el.addEventListener('mouseenter', () => scramble(el, original));
      });
    }
  </script>
</body>
</html>

  <style>
  body {
    padding-top: var(--nav-h);
  }

  .ambient-glow {
    position: fixed;
    top: 0; left: 0;
    width: 800px; height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(190, 210, 255, 0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
    transform: translate(-50%, -50%);
    will-change: transform;
  }

  .shell-grid {
    position: relative;
    width: 100%;
    min-height: calc(100vh - var(--nav-h));
  }

  .main {
    width: 100%;
    min-width: 0;
  }

  /* When article has a TOC, two-column shell with TOC floating right */
  .main--with-toc {
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: var(--shell-px);
    padding-right: 280px;
    padding-block: var(--s-10) var(--s-14);
  }

  .toc-aside {
    position: fixed;
    top: calc(var(--nav-h) + var(--s-8));
    right: max(var(--shell-px), calc((100vw - 1200px) / 2 + var(--shell-px)));
    width: 220px;
    max-height: calc(100vh - var(--nav-h) - var(--s-10));
    overflow-y: auto;
    z-index: 50;
  }

  @media (max-width: 1100px) {
    .main--with-toc { padding-right: var(--shell-px); }
    .toc-aside { display: none; }
  }
</style>
