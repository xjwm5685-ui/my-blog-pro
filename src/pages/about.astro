---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const techStack = [
  { name: 'Python',     pct: 100, desc: '主要开发语言 · 脚本与自动化' },
  { name: 'Java',       pct:  80, desc: 'Java SE · 面向对象设计' },
  { name: 'JavaScript', pct:  70, desc: '基本前端开发 · DOM · 工具脚本' },
  { name: 'Vue',        pct:  70, desc: 'Vue 生态 · 组件化开发' },
  { name: 'SpringBoot', pct:  60, desc: '后端服务 · REST · 中间件' },
  { name: 'HTML / CSS', pct:  60, desc: '页面布局 · 样式调整' },
  { name: 'C++',        pct:  40, desc: '算法学习 · 底层逻辑' }
];

const focusAreas = [
  { label: 'Tech',    cn: '技术笔记',   note: 'Python · Java · SpringBoot 学习心得与踩坑记录' },
  { label: 'Build',   cn: '项目实战',   note: '个人项目的开发过程复盘与技术总结' },
  { label: 'Algo',    cn: '算法与逻辑', note: 'C++ 算法学习与思考' },
  { label: 'Notes',   cn: '生活随笔',   note: '阅读、旅行、时间感与日常感悟' }
];
---

<BaseLayout
  title={`关于 · ABOUT — ${SITE_CONFIG.title}`}
  description={`关于 ${SITE_CONFIG.author}`}
>
  <div class="about shell">
    <header class="about__hero" data-reveal>
      <span class="bracket-label">ABOUT</span>
      <h1 class="about__title">
        Hi, I'm <span class="hl">{SITE_CONFIG.authorEn}</span>.<br/>
        <span class="about__title-cn">你好，我是 {SITE_CONFIG.author}。</span>
      </h1>
      <p class="about__lede">
        一名热衷于计算机技术的开发者与学习者，ID 是 <strong>WYHEF</strong>（五氧化二钒的缩写）。
        我喜欢探索代码背后的逻辑，也享受用工具去解决具体问题。
      </p>
    </header>

    <div class="about__grid">
      <!-- LEFT: profile -->
      <aside class="profile">
        <div class="profile__portrait" data-reveal>
          <img src={SITE_CONFIG.avatar} alt={SITE_CONFIG.author} loading="lazy" />
          <span class="profile__corner profile__corner--tl"></span>
          <span class="profile__corner profile__corner--tr"></span>
          <span class="profile__corner profile__corner--bl"></span>
          <span class="profile__corner profile__corner--br"></span>
        </div>

        <div class="profile__name" data-reveal style="--reveal-delay: 80ms">
          <h2 class="profile__title">{SITE_CONFIG.authorEn}</h2>
          <span class="profile__sub">{SITE_CONFIG.author}</span>
        </div>

        <ul class="profile__links" data-reveal style="--reveal-delay: 160ms">
          <li><a class="profile__link" href={SITE_CONFIG.github}   target="_blank" rel="noopener"><span class="bracket-label">GH</span><span>GitHub</span><span class="arrow">↗</span></a></li>
          <li><a class="profile__link" href={SITE_CONFIG.bilibili} target="_blank" rel="noopener"><span class="bracket-label">BL</span><span>Bilibili</span><span class="arrow">↗</span></a></li>
          <li><a class="profile__link" href={`mailto:${SITE_CONFIG.email}`}><span class="bracket-label">EM</span><span>{SITE_CONFIG.email}</span></a></li>
          <li class="profile__link wechat"><span class="bracket-label">WX</span><span>{SITE_CONFIG.wechat}</span>
            <div class="qr">
              <img src="/qrcode.jpg" alt="WeChat QR" />
              <span>扫码关注</span>
            </div>
          </li>
        </ul>
      </aside>

      <!-- RIGHT: long-form -->
      <article class="bio">
        <section class="bio__section" data-reveal>
          <span class="bracket-label">SECTION · 01</span>
          <h3>关于本站</h3>
          <p>
            建立这个博客是为了构建一个属于自己的知识库。在这个信息碎片化的时代，
            我希望通过长文写作来沉淀思考，记录学习过程中的灵光一现。
          </p>

          <ul class="focus-list">
            {focusAreas.map(f => (
              <li>
                <span class="focus-list__bracket">[ {f.label.toUpperCase()} ]</span>
                <span class="focus-list__cn">{f.cn}</span>
                <span class="focus-list__note">{f.note}</span>
              </li>
            ))}
          </ul>
        </section>

        <section class="bio__section" data-reveal>
          <span class="bracket-label">SECTION · 02</span>
          <h3>技术栈</h3>
          <p>以下是我目前主要使用的技术工具与熟练度。</p>

          <div class="stack">
            {techStack.map((t, i) => (
              <div class="stack__row" style={`--i: ${i};`} data-stack-row data-pct={t.pct}>
                <div class="stack__head">
                  <span class="stack__name">{t.name}</span>
                  <span class="stack__pct" data-stack-pct>000%</span>
                </div>
                <div class="stack__bar"><span data-stack-fill></span></div>
                <span class="stack__desc">{t.desc}</span>
              </div>
            ))}
          </div>
        </section>

        <section class="bio__section" data-reveal>
          <span class="bracket-label">SECTION · 03</span>
          <h3>联系我</h3>
          <p>
            如果你对我的文章感兴趣，或者有技术问题想要交流，欢迎通过左侧的社交链接联系我。
            你也可以关注我的微信公众号 <strong>"五氧化二钒不是废钒"</strong> 获取更多动态。
          </p>
        </section>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .about { padding-block: var(--s-10) var(--s-14); }

  .about__hero {
    max-width: 960px;
    margin-bottom: var(--s-10);
  }
  .about__title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: 1rem;
    color: var(--text);
  }
  .about__title .hl {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
  }
  .about__title-cn {
    font-family: var(--font-cn);
    font-size: 0.6em;
    color: var(--text-dim);
    font-weight: 300;
  }
  .about__lede {
    margin-top: 1rem;
    color: var(--text-dim);
    font-family: var(--font-cn);
    font-size: 1.05rem;
    line-height: 1.65;
    max-width: 56ch;
  }
  .about__lede strong { color: var(--text); font-weight: 500; }

  .about__grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  /* ====== LEFT PROFILE ====== */
  .profile {
    position: sticky;
    top: calc(var(--nav-h) + var(--s-6));
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .profile__portrait {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: var(--bg-card);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .profile__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2) contrast(1.06);
    transition: filter var(--dur) var(--ease-soft);
  }
  .profile__portrait:hover img { filter: grayscale(0) contrast(1.1); }

  .profile__corner {
    position: absolute;
    width: 12px; height: 12px;
    border: 0 solid var(--text);
    opacity: 0.55;
  }
  .profile__corner--tl { top: 6px; left: 6px;   border-top-width: 1px; border-left-width: 1px; }
  .profile__corner--tr { top: 6px; right: 6px;  border-top-width: 1px; border-right-width: 1px; }
  .profile__corner--bl { bottom: 6px; left: 6px; border-bottom-width: 1px; border-left-width: 1px; }
  .profile__corner--br { bottom: 6px; right: 6px; border-bottom-width: 1px; border-right-width: 1px; }

  .profile__name { display: flex; flex-direction: column; gap: 0.25rem; }
  .profile__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.015em;
  }
  .profile__sub {
    font-family: var(--font-cn);
    font-size: 0.86rem;
    color: var(--text-dim);
  }

  .profile__links {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .profile__links li { border-bottom: 1px solid var(--border); }

  .profile__link {
    position: relative;
    display: grid;
    grid-template-columns: 36px 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 0;
    color: var(--text-soft);
    transition: color var(--dur-fast) var(--ease-soft);
    font-family: var(--font-cn);
    font-size: 0.88rem;
  }
  .profile__link .bracket-label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--text-faint);
  }
  .profile__link:hover { color: var(--text); }
  .profile__link .arrow { color: var(--text-muted); }

  .profile__link.wechat { cursor: help; }
  .profile__link.wechat:hover .qr {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .qr {
    position: absolute;
    left: calc(100% + 1rem);
    top: 50%;
    transform: translate(-10px, -50%);
    width: 160px;
    background: var(--bg-card);
    border: 1px solid var(--border-strong);
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur) var(--ease-soft), transform var(--dur) var(--ease-soft);
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.7);
    z-index: 30;
  }
  .qr img { width: 140px; height: 140px; object-fit: contain; }
  .qr span {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* ====== RIGHT BIO ====== */
  .bio { display: flex; flex-direction: column; gap: var(--s-10); }

  .bio__section {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .bio__section h3 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.6rem;
    color: var(--text);
    letter-spacing: -0.015em;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .bio__section p {
    color: var(--text-soft);
    font-family: var(--font-cn);
    font-size: 0.98rem;
    line-height: 1.75;
    max-width: 64ch;
  }
  .bio__section p strong { color: var(--text); font-weight: 500; }

  /* focus list */
  .focus-list {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    max-width: 640px;
  }
  .focus-list li {
    display: grid;
    grid-template-columns: 70px 100px 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.7rem 0;
    border-bottom: 1px dashed var(--border);
    font-family: var(--font-cn);
  }
  .focus-list__bracket {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    color: var(--text-muted);
  }
  .focus-list__cn { color: var(--text); font-size: 0.95rem; }
  .focus-list__note { color: var(--text-dim); font-size: 0.86rem; }

  /* tech stack */
  .stack {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    margin-top: 1rem;
  }
  .stack__row { display: flex; flex-direction: column; gap: 0.4rem; }
  .stack__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .stack__name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--text);
  }
  .stack__pct {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--text-muted);
  }
  .stack__bar {
    width: 100%;
    height: 1px;
    background: var(--border);
    overflow: visible;
    position: relative;
  }
  .stack__bar span {
    display: block;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, rgba(190, 210, 255, 0.65), rgba(255, 255, 255, 0.95));
    box-shadow: 0 0 12px rgba(190, 210, 255, 0.45);
    transform-origin: left;
    transition: width 1500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .stack__bar span::after {
    content: '';
    position: absolute;
    top: -2px;
    right: -1px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #fff;
    box-shadow:
      0 0 8px rgba(255, 255, 255, 0.95),
      0 0 18px rgba(190, 210, 255, 0.7);
    opacity: 0;
    transition: opacity 1200ms ease 600ms;
  }
  .stack__row.is-counted .stack__bar span::after { opacity: 1; }
  .stack__pct {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--text);
  }
  .stack__desc {
    font-family: var(--font-cn);
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  @media (max-width: 900px) {
    .about__grid { grid-template-columns: 1fr; }
    .profile {
      position: static;
      display: grid;
      grid-template-columns: 140px 1fr;
      gap: 1.2rem;
      padding-bottom: var(--s-6);
      border-bottom: 1px solid var(--border);
      margin-bottom: var(--s-6);
    }
    .profile__portrait { width: 140px; }
    .profile__name, .profile__links { grid-column: 2; }
    .qr {
      left: 0;
      top: calc(100% + 0.5rem);
      transform: translateY(-10px);
    }
    .profile__link.wechat:hover .qr { transform: translateY(0); }
    .focus-list li { grid-template-columns: 80px 1fr; row-gap: 0.25rem; }
    .focus-list__note { grid-column: 1 / -1; }
  }
</style>

<script>
  /* Tech-stack count-up — bar fills + percent ticks from 0 to its target
     when the row scrolls into view. */
  function bootStackCount() {
    const rows = document.querySelectorAll<HTMLElement>('[data-stack-row]');
    if (!rows.length) return;

    const animateRow = (row: HTMLElement, delay: number) => {
      const target = Number(row.dataset.pct || '0');
      const fill   = row.querySelector<HTMLElement>('[data-stack-fill]');
      const pctEl  = row.querySelector<HTMLElement>('[data-stack-pct]');
      const dur    = 1500;
      const start  = performance.now() + delay;

      // bar uses CSS transition, just set width after a small delay
      window.setTimeout(() => {
        if (fill) fill.style.width = target + '%';
        row.classList.add('is-counted');
      }, delay);

      const ease = (t: number) => 1 - Math.pow(1 - t, 3); // easeOutCubic
      const tick = (now: number) => {
        const elapsed = now - start;
        if (elapsed < 0) { requestAnimationFrame(tick); return; }
        const t = Math.min(1, elapsed / dur);
        const v = Math.round(ease(t) * target);
        if (pctEl) pctEl.textContent = v.toString().padStart(3, '0') + '%';
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e, idx) => {
        if (!e.isIntersecting) return;
        const row = e.target as HTMLElement;
        if ((row as any).__counted) return;
        (row as any).__counted = true;
        const i = Number(row.style.getPropertyValue('--i')) || 0;
        animateRow(row, i * 90);
        io.unobserve(row);
      });
    }, { threshold: 0.4 });
    rows.forEach(r => io.observe(r));
  }

  bootStackCount();
  document.addEventListener('astro:page-load', bootStackCount);
</script>
