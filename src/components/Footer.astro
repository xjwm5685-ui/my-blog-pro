---
import { SITE_CONFIG } from '@/config';
import Equalizer from './Equalizer.astro';
const year = new Date().getFullYear();
---

<footer class="ftr">
  <div class="ftr__top">
    <div class="ftr__col">
      <span class="bracket-label">FOLLOW</span>
      <ul>
        <li><a href={SITE_CONFIG.github} target="_blank" rel="noopener">GitHub</a></li>
        <li><a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener">Bilibili</a></li>
        <li><a href={`mailto:${SITE_CONFIG.email}`}>Email</a></li>
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </div>

    <div class="ftr__col">
      <span class="bracket-label">CATEGORIES</span>
      <ul>
        <li><a href="/category/tech">技术</a></li>
        <li><a href="/category/notes">笔记</a></li>
        <li><a href="/category/travel">游记</a></li>
        <li><a href="/tags">所有标签</a></li>
      </ul>
    </div>

    <div class="ftr__col">
      <span class="bracket-label">EXPLORE</span>
      <ul>
        <li><a href="/blog">归档</a></li>
        <li><a href="/projects">成品项目</a></li>
        <li><a href="/videos">视频教程</a></li>
        <li><a href="/about">关于</a></li>
      </ul>
    </div>

    <div class="ftr__col">
      <span class="bracket-label">CONTACT</span>
      <ul>
        <li><span class="muted">{SITE_CONFIG.email}</span></li>
        <li><span class="muted">微信公众号</span></li>
        <li><span class="muted">{SITE_CONFIG.wechat}</span></li>
      </ul>
    </div>

    <div class="ftr__col ftr__brand">
      <a href="/" class="ftr__wordmark">{SITE_CONFIG.shortTitle}</a>
      <p class="ftr__tag">{SITE_CONFIG.subtitle}</p>
      <div class="ftr__live">
        <Equalizer />
        <span class="ftr__live-text">
          <span class="ftr__live-label">BROADCASTING</span>
          <span class="ftr__live-since">EST · 2024</span>
        </span>
      </div>
    </div>
  </div>

  <div class="ftr__bottom">
    <span class="mono">© {year} {SITE_CONFIG.author} · ALL RIGHTS RESERVED</span>
    <span class="mono ftr__site">BUILT WITH ASTRO · DEPLOYED ON VERCEL</span>
  </div>
</footer>

<style>
  .ftr {
    margin-top: var(--s-20);
    padding: var(--s-10) var(--shell-px) var(--s-6);
    border-top: 1px solid var(--border);
    background: linear-gradient(180deg, transparent, rgba(255,255,255,0.015));
  }

  .ftr__top {
    display: grid;
    grid-template-columns: repeat(4, 1fr) 1.4fr;
    gap: 2.4rem;
    padding-bottom: var(--s-8);
  }

  .ftr__col { display: flex; flex-direction: column; gap: 1rem; }

  .ftr__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ftr__col li {
    font-family: var(--font-cn);
    font-size: 0.84rem;
  }
  .ftr__col a {
    color: var(--text-soft);
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .ftr__col a:hover { color: var(--text); }
  .ftr__col .muted { color: var(--text-muted); font-size: 0.8rem; }

  .ftr__brand { gap: 0.6rem; }
  .ftr__wordmark {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: clamp(2.2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1;
  }
  .ftr__tag {
    color: var(--text-dim);
    font-family: var(--font-cn);
    font-size: 0.85rem;
    margin: 0;
  }

  .ftr__live {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    margin-top: 0.6rem;
    padding: 0.45rem 0.9rem 0.45rem 0.6rem;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    width: fit-content;
  }
  .ftr__live-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
    font-family: var(--font-mono);
  }
  .ftr__live-label {
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text);
  }
  .ftr__live-since {
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    color: var(--text-muted);
  }

  .ftr__bottom {
    border-top: 1px solid var(--border);
    padding-top: var(--s-5);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-muted);
  }
  .mono {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .ftr__top { grid-template-columns: repeat(2, 1fr); }
    .ftr__brand { grid-column: 1 / -1; order: -1; padding-bottom: 1rem; border-bottom: 1px solid var(--border); }
  }
  @media (max-width: 600px) {
    .ftr__top { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .ftr__bottom { flex-direction: column; gap: 0.6rem; align-items: flex-start; }
    .ftr__site { font-size: 0.62rem; }
  }
</style>
