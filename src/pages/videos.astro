---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE_CONFIG } from '@/config';

const videos = [
  { bvid: 'BV1wXQHYBEtt' },
  { bvid: 'BV1FJKezFETE' },
  { bvid: 'BV1GQKYzEEfs' },
  { bvid: 'BV1yqrNBoEh3' },
  { bvid: 'BV1m8rNBaEaX' },
  { bvid: 'BV1M8rNBYEj2' },
  { bvid: 'BV1ubrNBPEg3' },
  { bvid: 'BV1UbrNBAEGD' },
  { bvid: 'BV1UbrNBAE3n' },
  { bvid: 'BV12YrNB8EW8' },
  { bvid: 'BV1xYrNBhEZe' },
  { bvid: 'BV14YrNBhEqb' }
];
---

<BaseLayout
  title={`视频教程 · VIDEOS — ${SITE_CONFIG.title}`}
  description={`${SITE_CONFIG.author}的B站视频教程合集`}
>
  <div class="vid shell">
    <header class="vid__head" data-reveal>
      <span class="bracket-label">VIDEOS</span>
      <h1 class="vid__title">
        视频教程<br/>
        <span class="vid__title-en">A small library of walkthroughs.</span>
      </h1>
      <p class="vid__lede">
        我在 B 站发布的教程视频合集。
        <a href={SITE_CONFIG.bilibili} target="_blank" rel="noopener" class="vid__inline-link">关注 B 站频道 ↗</a>
        获取更多内容。
      </p>
    </header>

    <div class="vid__grid">
      {videos.map((v, i) => (
        <article class="vcard" data-reveal style={`--reveal-delay: ${(i % 6) * 70}ms;`}>
          <div class="vcard__head">
            <span class="vcard__index">#{(i + 1).toString().padStart(2, '0')}</span>
            <span class="bracket-label">BILIBILI</span>
          </div>

          <div class="vcard__player">
            <iframe
              src={`//player.bilibili.com/player.html?bvid=${v.bvid}&page=1&high_quality=1`}
              loading="lazy"
              allowfullscreen
              frameborder="0"
              scrolling="no"
            ></iframe>
          </div>

          <a class="vcard__cta pill pill--ghost" href={`https://www.bilibili.com/video/${v.bvid}`} target="_blank" rel="noopener">
            WATCH ON BILIBILI <span class="arrow">↗</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .vid { padding-block: var(--s-10) var(--s-14); }

  .vid__head { max-width: 800px; margin-bottom: var(--s-10); }
  .vid__title {
    margin-top: 1rem;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .vid__title-en {
    font-family: var(--font-display);
    font-size: 0.55em;
    color: var(--text-muted);
    font-style: italic;
  }
  .vid__lede {
    margin-top: 1rem;
    color: var(--text-dim);
    font-family: var(--font-cn);
    font-size: 1rem;
    line-height: 1.65;
  }
  .vid__inline-link {
    color: var(--text);
    border-bottom: 1px solid var(--border-strong);
  }
  .vid__inline-link:hover { border-bottom-color: var(--beam-cool); }

  .vid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }
  @media (max-width: 1100px) { .vid__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px)  { .vid__grid { grid-template-columns: 1fr; } }

  .vcard {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: border-color var(--dur) var(--ease-soft);
  }
  .vcard:hover { border-color: var(--border-strong); }

  .vcard__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .vcard__index {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: var(--text);
  }

  .vcard__player {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    background: var(--bg-elev);
    overflow: hidden;
  }
  .vcard__player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .vcard__cta { align-self: flex-start; }
</style>
