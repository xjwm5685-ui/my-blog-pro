---
/**
 * LightBeam — luminous beam that emerges from the right edge.
 * Layered SVG + CSS gradients with cursor-driven parallax depth.
 *
 * Each layer (mist · halo · core · streaks) sits at a different
 * translateZ depth so cursor movement separates them volumetrically.
 *
 * Props:
 *   side: 'right' | 'left'  default 'right'
 *   intensity: 0 - 1        default 1
 *   parallax: bool          default true
 */
interface Props {
  side?: 'right' | 'left';
  intensity?: number;
  parallax?: boolean;
}
const { side = 'right', intensity = 1, parallax = true } = Astro.props;
---

<div
  class:list={['beam', `beam--${side}`, { 'beam--parallax': parallax }]}
  style={`--beam-intensity: ${intensity};`}
  data-parallax={parallax ? '1' : '0'}
  aria-hidden="true"
>
  <div class="beam__layer beam__mist"></div>
  <div class="beam__layer beam__halo"></div>
  <div class="beam__layer beam__core"></div>
  <svg class="beam__layer beam__rays" viewBox="0 0 800 800" preserveAspectRatio="xMidYMid slice">
    <defs>
      <radialGradient id="rayGrad" cx="78%" cy="50%" r="55%">
        <stop offset="0%"   stop-color="rgba(255,255,255,0.95)"/>
        <stop offset="22%"  stop-color="rgba(220,230,255,0.55)"/>
        <stop offset="55%"  stop-color="rgba(140,170,230,0.18)"/>
        <stop offset="100%" stop-color="rgba(0,0,0,0)"/>
      </radialGradient>
      <radialGradient id="rayWarm" cx="82%" cy="50%" r="40%">
        <stop offset="0%"   stop-color="rgba(255,240,220,0.55)"/>
        <stop offset="60%"  stop-color="rgba(255,210,170,0.10)"/>
        <stop offset="100%" stop-color="rgba(0,0,0,0)"/>
      </radialGradient>
    </defs>
    <rect width="800" height="800" fill="url(#rayGrad)"/>
    <rect width="800" height="800" fill="url(#rayWarm)" opacity="0.6"/>
    <g class="beam__streaks" stroke="rgba(255,255,255,0.06)" stroke-width="0.6" fill="none">
      <line x1="780" y1="400" x2="160" y2="240" />
      <line x1="780" y1="400" x2="200" y2="320" />
      <line x1="780" y1="400" x2="180" y2="520" />
      <line x1="780" y1="400" x2="120" y2="420" />
      <line x1="780" y1="400" x2="240" y2="600" />
    </g>
  </svg>
  <div class="beam__layer beam__dust" aria-hidden="true">
    {Array.from({ length: 14 }).map((_, i) => (
      <span class="dot" style={`--di: ${i};`}></span>
    ))}
  </div>
</div>

<style>
  .beam {
    --px: 0;
    --py: 0;
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: var(--beam-intensity, 1);
    z-index: 0;
    perspective: 1400px;
    transform-style: preserve-3d;
  }

  .beam__layer {
    position: absolute;
    top: 50%;
    will-change: transform, opacity;
    transition: transform 380ms var(--ease-soft);
  }
  .beam--right .beam__layer:not(.beam__rays):not(.beam__dust) { right: -10%; }
  .beam--left  .beam__layer:not(.beam__rays):not(.beam__dust) { left:  -10%; transform: scaleX(-1); }

  .beam__core {
    width: 65vw;
    height: 70vh;
    transform: translate3d(calc(var(--px) * -16px), calc(-50% + var(--py) * -10px), 60px);
    background:
      radial-gradient(ellipse 60% 18% at 90% 50%,
        rgba(255, 255, 255, 0.95) 0%,
        rgba(225, 235, 255, 0.55) 18%,
        rgba(150, 175, 230, 0.18) 45%,
        transparent 75%);
    filter: blur(2px);
    animation: beamDrift 11s ease-in-out infinite;
  }

  .beam__halo {
    width: 95vw;
    height: 110vh;
    transform: translate3d(calc(var(--px) * -8px), calc(-50% + var(--py) * -6px), 30px);
    background:
      radial-gradient(ellipse 55% 30% at 95% 50%,
        rgba(190, 210, 255, 0.30) 0%,
        rgba(130, 160, 220, 0.12) 30%,
        transparent 70%);
    filter: blur(40px);
    animation: beamPulse 7s ease-in-out infinite;
  }

  .beam__mist {
    width: 120vw;
    height: 130vh;
    transform: translate3d(calc(var(--px) * -3px), calc(-50% + var(--py) * -2px), -20px);
    background:
      radial-gradient(ellipse 70% 50% at 92% 50%,
        rgba(80, 110, 180, 0.18) 0%,
        rgba(40, 60, 110, 0.06) 35%,
        transparent 70%);
    filter: blur(80px);
    animation: beamPulse 13s ease-in-out infinite reverse;
  }

  .beam__rays {
    position: absolute;
    top: -10%;
    right: -25%;
    width: 110%;
    height: 120%;
    opacity: 0.85;
    transform: translate3d(calc(var(--px) * -22px), calc(var(--py) * -14px), 90px);
    transition: transform 380ms var(--ease-soft);
  }
  .beam--left .beam__rays {
    right: auto;
    left: -25%;
    transform: translate3d(calc(var(--px) * 22px), calc(var(--py) * -14px), 90px) scaleX(-1);
  }

  .beam__streaks {
    transform-origin: 780px 400px;
    animation: spin 220s linear infinite;
    opacity: 0.5;
  }

  /* drifting motes — particle-like dust in front of the beam */
  .beam__dust {
    position: absolute;
    inset: 0;
    transform: translate3d(calc(var(--px) * -34px), calc(var(--py) * -22px), 140px);
    transition: transform 380ms var(--ease-soft);
    pointer-events: none;
  }
  .beam__dust .dot {
    position: absolute;
    width: 2px;
    height: 2px;
    background: rgba(225, 235, 255, 0.85);
    border-radius: 50%;
    box-shadow: 0 0 6px rgba(190, 210, 255, 0.6);
    top: calc(20% + (var(--di) * 4.7%));
    right: calc(8% + (var(--di) * 3.1%));
    opacity: 0;
    animation:
      dustFloat 14s ease-in-out infinite,
      dustTwinkle 3s ease-in-out infinite;
    animation-delay: calc(var(--di) * -0.7s), calc(var(--di) * -0.2s);
  }

  @keyframes dustFloat {
    0%, 100% { transform: translate(0, 0); opacity: 0; }
    10%      { opacity: 0.7; }
    50%      { transform: translate(-40px, -30px); opacity: 1; }
    90%      { opacity: 0.4; }
  }
  @keyframes dustTwinkle {
    0%, 100% { filter: brightness(0.7); }
    50%      { filter: brightness(1.4); }
  }

  @media (max-width: 768px) {
    .beam__core { width: 110vw; height: 60vh; }
    .beam__halo { width: 140vw; }
  }

  @media (prefers-reduced-motion: reduce) {
    .beam__layer, .beam__dust { transition: none !important; transform: translateY(-50%) !important; }
  }
</style>

<script>
  function bindBeam(beam: HTMLElement) {
    if (beam.dataset.parallax !== '1') return;

    // climb up to a sensible parallax host (the hero / 404 section), or fall back to window
    let host: HTMLElement | Window = beam.parentElement?.closest('section, header, .hero, .four') as HTMLElement
      || window;

    let raf = 0;
    let tx = 0, ty = 0;       // target normalised
    let cx = 0, cy = 0;       // current

    const apply = () => {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;
      beam.style.setProperty('--px', cx.toFixed(3));
      beam.style.setProperty('--py', cy.toFixed(3));
      if (Math.abs(tx - cx) + Math.abs(ty - cy) > 0.0008) {
        raf = requestAnimationFrame(apply);
      } else {
        raf = 0;
      }
    };

    const onMove = (e: MouseEvent) => {
      let rect: DOMRect;
      if (host instanceof HTMLElement) {
        rect = host.getBoundingClientRect();
      } else {
        rect = { left: 0, top: 0, width: window.innerWidth, height: window.innerHeight } as DOMRect;
      }
      tx = ((e.clientX - rect.left) / rect.width)  * 2 - 1;
      ty = ((e.clientY - rect.top)  / rect.height) * 2 - 1;
      if (!raf) raf = requestAnimationFrame(apply);
    };
    const onLeave = () => {
      tx = 0; ty = 0;
      if (!raf) raf = requestAnimationFrame(apply);
    };

    if (host instanceof HTMLElement) {
      host.addEventListener('mousemove', onMove);
      host.addEventListener('mouseleave', onLeave);
    } else {
      host.addEventListener('mousemove', onMove as EventListener);
    }
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.beam').forEach((b) => {
      if ((b as any).__bound) return;
      (b as any).__bound = true;
      bindBeam(b);
    });
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
