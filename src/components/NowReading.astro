---
/**
 * NowReading — small floating widget at bottom-right of the homepage.
 * Mimics a "now playing" UI. Shows the most recent article with
 * title, date, and a subtle pulsing waveform.
 *
 * Props:
 *   title: string
 *   slug:  string
 *   date:  Date
 */
import { formatDate } from '@/utils/post';

interface Props {
  title: string;
  slug:  string;
  date:  Date;
}
const { title, slug, date } = Astro.props;
---
<a class="nr" href={`/blog/${slug}`} aria-label={`Now reading: ${title}`}>
  <span class="nr__bars" aria-hidden="true">
    {Array.from({ length: 5 }).map((_, i) => (
      <span class="nr__bar" style={`--i: ${i};`}></span>
    ))}
  </span>
  <span class="nr__copy">
    <span class="nr__label">NOW READING</span>
    <span class="nr__title">{title}</span>
    <span class="nr__date">{formatDate(date)}</span>
  </span>
  <span class="nr__arrow" aria-hidden="true">↗</span>
</a>

<style>
  .nr {
    position: fixed;
    right: var(--shell-px);
    bottom: 1.4rem;
    z-index: 940;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.6rem 0.95rem 0.6rem 0.85rem;
    background: rgba(0, 0, 0, 0.65);
    border: 1px solid var(--border);
    border-radius: 14px;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    color: var(--text-soft);
    text-decoration: none;
    transition:
      border-color var(--dur) var(--ease-soft),
      background var(--dur) var(--ease-soft),
      transform var(--dur) var(--ease-soft);
    opacity: 0;
    transform: translateY(20px);
    animation: nrIn 900ms var(--ease-out) 1.8s forwards;
    max-width: 340px;
  }
  @keyframes nrIn { to { opacity: 1; transform: translateY(0); } }
  .nr:hover {
    border-color: var(--border-strong);
    background: rgba(20, 20, 20, 0.85);
    transform: translateY(-2px);
  }

  .nr__bars {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    height: 28px;
    flex-shrink: 0;
  }
  .nr__bar {
    width: 2px;
    background: linear-gradient(to top, rgba(190,210,255,0.85), rgba(255,255,255,0.95));
    box-shadow: 0 0 5px rgba(190, 210, 255, 0.5);
    animation: nrBar calc(0.7s + var(--i) * 0.18s) ease-in-out infinite;
    animation-delay: calc(var(--i) * -0.21s);
    height: 30%;
  }
  @keyframes nrBar {
    0%, 100% { height: 22%; }
    50%      { height: 88%; }
  }

  .nr__copy {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1.25;
    min-width: 0;
  }
  .nr__label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .nr__title {
    font-family: var(--font-cn);
    font-size: 0.85rem;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 220px;
  }
  .nr__date {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    color: var(--text-faint);
  }

  .nr__arrow {
    font-family: var(--font-mono);
    color: var(--text-dim);
    flex-shrink: 0;
    transition: transform var(--dur) var(--ease-soft);
  }
  .nr:hover .nr__arrow { transform: translate(2px, -2px); color: var(--text); }

  @media (max-width: 720px) {
    .nr { display: none; }
  }
</style>
