---
/**
 * SectionIndicator — bottom-right floating HUD that updates with the
 * currently-visible section name as the user scrolls. Watches all
 * elements with [data-section-name] inside the page.
 */
---
<div class="si" data-si aria-hidden="true">
  <span class="si__chev">→</span>
  <span class="si__label" data-si-label>HERO</span>
</div>

<style>
  .si {
    position: fixed;
    right: var(--shell-px);
    bottom: 5.5rem;
    z-index: 935;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background: rgba(0, 0, 0, 0.55);
    border: 1px solid var(--border);
    border-radius: var(--r-pill);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-soft);
    pointer-events: none;
    opacity: 0;
    transform: translateY(8px);
    animation: siIn 900ms var(--ease-out) 2.0s forwards;
    transition: color 240ms ease, border-color 240ms ease;
  }
  @keyframes siIn { to { opacity: 1; transform: translateY(0); } }
  .si__chev {
    color: var(--text-muted);
    font-family: var(--font-display);
  }
  .si__label {
    color: var(--text);
    font-weight: 500;
  }
  @media (max-width: 720px) {
    .si { display: none; }
  }
</style>

<script>
  function bootSI() {
    const label = document.querySelector<HTMLElement>('[data-si-label]');
    if (!label) return;
    const sections = document.querySelectorAll<HTMLElement>('[data-section-name]');
    if (!sections.length) return;

    const io = new IntersectionObserver((entries) => {
      // pick the most-intersecting one
      let best: { el: HTMLElement; r: number } | null = null;
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        if (!best || e.intersectionRatio > best.r) {
          best = { el: e.target as HTMLElement, r: e.intersectionRatio };
        }
      }
      if (best) {
        const name = best.el.dataset.sectionName || '';
        if (label.textContent !== name) label.textContent = name;
      }
    }, { threshold: [0, 0.25, 0.5, 0.75, 1] });

    sections.forEach(s => io.observe(s));
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }
  bootSI();
  document.addEventListener('astro:page-load', bootSI);
</script>
