---
/**
 * CategoryCard — x.ai-style product card with full 3D tilt.
 *
 * Outer wrapper sets the perspective.
 * Inner card rotateX/Y based on cursor position.
 * Title / icon / pill float on different translateZ planes for parallax.
 */
interface Props {
  bracket: string;
  title: string;
  description: string;
  href: string;
  tagline?: string;
  icon: 'tech' | 'notes' | 'travel';
  index?: number;
}
const { bracket, title, description, href, tagline, icon, index = 0 } = Astro.props;
const delay = `${index * 120}ms`;
---

<div class="card-stage" data-reveal style={`--reveal-delay: ${delay};`}>
  <a class="card" href={href}>
    <span class="card__shine" aria-hidden="true"></span>
    <div class="card__grid-bg"></div>

    <div class="card__content-layer">
      <div class="card__head">
        <span class="card__bracket">[ {bracket} ]</span>
        <span class="card__index">0{index + 1}</span>
      </div>

      <div class="card__title-row">
        <h3 class="card__title" data-text={title}>{title}</h3>
        {tagline && <p class="card__tagline">{tagline}</p>}
      </div>

      <p class="card__desc">{description}</p>
    </div>

    <div class="card__art" aria-hidden="true">
      {icon === 'tech' && (
        <svg viewBox="0 0 240 140" width="100%" height="100%" fill="none" stroke="currentColor">
          <pattern id="tech-grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <rect width="10" height="10" fill="none" stroke="currentColor" stroke-width="0.1" opacity="0.3"/>
          </pattern>
          <rect x="20" y="10" width="200" height="120" fill="url(#tech-grid)" />
          
          <g stroke-width="0.5" opacity="0.7" class="icon-tech-traces">
            <polyline points="40,70 70,70 80,60 90,60"/>
            <polyline points="40,80 60,80 70,90 90,90"/>
            <polyline points="200,60 170,60 160,50 150,50"/>
            <polyline points="200,80 180,80 170,90 150,90"/>
            <polyline points="120,20 120,40"/>
            <polyline points="120,120 120,100"/>
            <polyline points="140,20 140,30 130,40"/>
            <polyline points="100,120 100,110 110,100"/>
          </g>
          
          <circle cx="40" cy="70" r="1.5" fill="currentColor"/>
          <circle cx="40" cy="80" r="1.5" fill="currentColor"/>
          <circle cx="200" cy="60" r="1.5" fill="currentColor"/>
          <circle cx="200" cy="80" r="1.5" fill="currentColor"/>
          
          <rect x="90" y="40" width="60" height="60" rx="2" fill="var(--bg-card)" stroke-width="1"/>
          <rect x="94" y="44" width="52" height="52" stroke-width="0.5" stroke-dasharray="2 2"/>
          
          <g class="icon-tech-core">
            <rect x="105" y="55" width="30" height="30" fill="var(--bg-card)" stroke-width="1"/>
            <circle cx="120" cy="70" r="4" fill="currentColor"/>
            <circle cx="120" cy="70" r="10" stroke-width="0.5" stroke-dasharray="1 3"/>
          </g>
        </svg>
      )}
      {icon === 'notes' && (
        <svg viewBox="0 0 240 140" width="100%" height="100%" fill="none" stroke="currentColor">
          <g class="icon-notes-layer icon-notes-layer--2">
            <path d="M40 18 L180 18 L200 38 L200 122 L40 122 Z" fill="var(--bg-card)" stroke-width="0.75"/>
            <path d="M180 18 L180 38 L200 38" fill="var(--bg-card)" stroke-width="0.75"/>
            <line x1="55" y1="45" x2="160" y2="45" stroke-width="0.3"/>
            <line x1="55" y1="55" x2="160" y2="55" stroke-width="0.3"/>
          </g>
          <g class="icon-notes-layer icon-notes-layer--1">
            <path d="M40 18 L180 18 L200 38 L200 122 L40 122 Z" fill="var(--bg-card)" stroke-width="0.75"/>
            <path d="M180 18 L180 38 L200 38" fill="var(--bg-card)" stroke-width="0.75"/>
            <line x1="55" y1="45" x2="160" y2="45" stroke-width="0.3"/>
            <line x1="55" y1="55" x2="160" y2="55" stroke-width="0.3"/>
          </g>
          <g class="icon-notes-layer icon-notes-layer--main">
            <path d="M40 18 L180 18 L200 38 L200 122 L40 122 Z" fill="var(--bg-card)" stroke-width="0.75"/>
            <path d="M180 18 L180 38 L200 38" fill="var(--bg-card)" stroke-width="0.75"/>
            <rect x="55" y="35" width="20" height="20" stroke-width="0.5"/>
            <circle cx="65" cy="45" r="4" stroke-width="0.5"/>
            <line x1="85" y1="38" x2="170" y2="38" stroke-width="1"/>
            <line x1="85" y1="46" x2="140" y2="46" stroke-width="0.5"/>
            <line x1="85" y1="52" x2="155" y2="52" stroke-width="0.5"/>
            <line x1="55" y1="70" x2="180" y2="70" stroke-width="0.5"/>
            <line x1="55" y1="80" x2="170" y2="80" stroke-width="0.5"/>
            <line x1="55" y1="90" x2="180" y2="90" stroke-width="0.5"/>
            <line x1="55" y1="100" x2="140" y2="100" stroke-width="0.5"/>
            <rect x="45" y="70" width="3" height="3" fill="currentColor"/>
            <rect x="45" y="80" width="3" height="3" stroke-width="0.5"/>
            <rect x="45" y="90" width="3" height="3" fill="currentColor"/>
            <path d="M150 105 v10 M155 105 v10 M158 105 v10 M162 105 v10 M168 105 v10 M172 105 v10 M180 105 v10" stroke-width="1"/>
          </g>
        </svg>
      )}
      {icon === 'travel' && (
        <svg viewBox="0 0 240 140" width="100%" height="100%" fill="none" stroke="currentColor">
          <circle cx="120" cy="70" r="60" stroke-width="0.2" opacity="0.5"/>
          <path d="M 60 70 A 60 60 0 0 1 180 70" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.8"/>
          
          <g class="icon-travel-ring-3">
            <circle cx="120" cy="70" r="50" stroke-width="3" stroke-dasharray="1 10" opacity="0.4"/>
          </g>
        
          <circle cx="120" cy="70" r="44" stroke-width="1"/>
          
          <g class="icon-travel-ring-1">
            <circle cx="120" cy="70" r="38" stroke-width="0.75" stroke-dasharray="15 5 4 5 8 5"/>
          </g>
          
          <g class="icon-travel-ring-2">
            <circle cx="120" cy="70" r="32" stroke-width="0.5" stroke-dasharray="2 4 10 4"/>
          </g>
        
          <line x1="45" y1="70" x2="72" y2="70" stroke-width="0.5"/>
          <line x1="168" y1="70" x2="195" y2="70" stroke-width="0.5"/>
          <line x1="120" y1="5" x2="120" y2="25" stroke-width="0.5"/>
          <line x1="120" y1="115" x2="120" y2="135" stroke-width="0.5"/>
          
          <circle cx="120" cy="70" r="8" stroke-width="0.5"/>
          <circle cx="120" cy="70" r="2" fill="currentColor"/>
          
          <rect x="180" y="25" width="20" height="4" stroke-width="0.5"/>
          <line x1="180" y1="33" x2="210" y2="33" stroke-width="0.5" stroke-dasharray="2 2"/>
        </svg>
      )}
    </div>

    <span class="card__cta">
      EXPLORE <span class="arrow">↗</span>
    </span>

    <span class="card__corner card__corner--tl"></span>
    <span class="card__corner card__corner--tr"></span>
    <span class="card__corner card__corner--bl"></span>
    <span class="card__corner card__corner--br"></span>

    <span class="card__particles">
      {Array.from({ length: 6 }).map((_, i) => (
        <span class="card__particle" style={`--pi: ${i};`}></span>
      ))}
    </span>
  </a>
</div>

<style>
  .card-stage {
    position: relative;
    z-index: 1;
  }

  .card-stack-layer {
    position: absolute;
    inset: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    z-index: 0;
    transform-origin: bottom left;
    transition: transform 500ms cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color var(--dur) var(--ease-soft),
                box-shadow var(--dur) var(--ease-soft),
                opacity var(--dur) var(--ease-soft);
    pointer-events: none;
  }

  .card-stack-layer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(190, 210, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(190, 210, 255, 0.02) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .card-stack-layer--1 {
    transform: translate(4px, -4px) rotate(1.5deg);
    opacity: 0.8;
  }
  
  .card-stack-layer--2 {
    transform: translate(8px, -8px) rotate(3deg);
    opacity: 0.5;
  }

  .card-stage:hover .card-stack-layer--1 {
    transform: translate(25px, -25px) rotate(8deg);
    border-color: #0ff;
    box-shadow: 0 10px 40px -10px rgba(0,255,255,0.4);
    opacity: 0.9;
  }

  .card-stage:hover .card-stack-layer--2 {
    transform: translate(50px, -50px) rotate(16deg);
    border-color: #f0f;
    box-shadow: 0 10px 40px -10px rgba(255,0,255,0.4);
    opacity: 0.7;
  }

  .card {
    --mx: 50%;
    --my: 50%;
    --rx: 0deg;
    --ry: 0deg;
    --lift: 0px;

    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: 1.6rem 1.5rem 1.4rem;
    min-height: 360px;
    background: rgba(13, 13, 13, 0.4);
    border: 1px solid var(--border);
    color: var(--text-soft);
    overflow: hidden;
    isolation: isolate;
    
    /* Base Liquid Glass Setup */
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);

    transform: perspective(1000px) translate3d(0, calc(var(--lift) * -1), 0) rotateX(var(--rx)) rotateY(var(--ry));
    transition:
      transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color var(--dur) var(--ease-soft),
      background-color var(--dur) var(--ease-soft),
      box-shadow var(--dur) var(--ease-soft),
      backdrop-filter var(--dur) var(--ease-soft);
    will-change: transform;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(320px circle at var(--mx) var(--my),
        rgba(190, 210, 255, 0.15),
        transparent 45%);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    pointer-events: none;
    z-index: 0;
  }

  /* Inner liquid edge reflection */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: radial-gradient(400px circle at var(--mx) var(--my), rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.05) 50%, transparent 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    pointer-events: none;
    z-index: 10;
  }

  /* moving glare strip — like light hitting liquid */
  .card__shine {
    position: absolute;
    inset: -10%;
    background: linear-gradient(
      105deg,
      transparent 38%,
      rgba(255, 255, 255, 0.15) 48%,
      rgba(190, 210, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.15) 52%,
      transparent 62%
    );
    transform: translateX(calc(var(--mx) - 50%));
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    pointer-events: none;
    mix-blend-mode: screen;
    z-index: 1;
  }

  .card:hover {
    --lift: 15px;
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(20, 20, 20, 0.6);
    /* Intense Liquid Glass Hover */
    backdrop-filter: blur(32px) saturate(200%);
    -webkit-backdrop-filter: blur(32px) saturate(200%);
    box-shadow:
      0 40px 80px -20px rgba(0, 0, 0, 0.9),
      0 20px 50px -10px rgba(190, 210, 255, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
      inset 0 20px 40px -20px rgba(190, 210, 255, 0.15); /* inner top glow */
  }
  .card:hover::before { opacity: 1; }
  .card:hover::after { opacity: 1; }
  .card:hover .card__shine { opacity: 1; }

  .card__grid-bg {
    position: absolute;
    inset: -20px;
    background-image: 
      linear-gradient(rgba(190, 210, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(190, 210, 255, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    opacity: 0;
    transform: translate(calc((var(--mx) - 50%) * -0.05), calc((var(--my) - 50%) * -0.05));
    transition: opacity var(--dur) var(--ease-soft), transform 100ms ease-out;
    pointer-events: none;
    z-index: 1;
  }
  .card:hover .card__grid-bg {
    opacity: 1;
  }

  @keyframes gridFloat {
    from { background-position: 0 0; }
    to { background-position: 20px 20px; }
  }

  .card__content-layer {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    z-index: 2;
    transition: transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  .card:hover .card__content-layer {
    transform: translateX(15px) !important;
  }

  /* Inner content — kept on the same plane for crisp text.
     Excludes absolutely-positioned overlays (shine, corners). */
  .card > *:not(.card__corner):not(.card__shine):not(.card__grid-bg):not(.card__particles) {
    position: relative;
    z-index: 2;
  }

  /* Corner brackets — true corners, no Z translation.
     `!important` guards against any blanket child rule above. */
  .card__corner {
    position: absolute !important;
    width: 12px;
    height: 12px;
    border: 0 solid var(--text);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-soft);
    pointer-events: none;
    z-index: 3;
  }
  .card__corner--tl { top: 8px    !important; left: 8px    !important; right: auto !important; bottom: auto !important; border-top-width: 1px; border-left-width: 1px; }
  .card__corner--tr { top: 8px    !important; right: 8px   !important; left: auto  !important; bottom: auto !important; border-top-width: 1px; border-right-width: 1px; }
  .card__corner--bl { bottom: 8px !important; left: 8px    !important; right: auto !important; top: auto    !important; border-bottom-width: 1px; border-left-width: 1px; }
  .card__corner--br { bottom: 8px !important; right: 8px   !important; left: auto  !important; top: auto    !important; border-bottom-width: 1px; border-right-width: 1px; }
  .card:hover .card__corner { opacity: 0.7; }

  .card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .card__bracket { color: var(--text-dim); }
  .card__index { color: var(--text-faint); }

  .card__title-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .card__title {
    position: relative;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.015em;
  }

  .card__title::before,
  .card__title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
  }

  .card:hover .card__title::before {
    opacity: 1;
    color: var(--beam-cool);
    z-index: -1;
    animation: glitchSlice 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }
  
  .card:hover .card__title::after {
    opacity: 1;
    color: var(--beam-warm);
    z-index: -2;
    animation: glitchSlice2 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }
  .card__tagline {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .card__desc {
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-dim);
    max-width: 32ch;
  }

  .card__art {
    flex: 1;
    min-height: 110px;
    margin-top: auto;
    color: var(--text-faint);
    transition: color var(--dur) var(--ease-soft), transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .card:hover .card__art { 
    color: var(--text-dim); 
    transform: scale(1.05) !important;
  }

  /* SVG Stacking Effect for Notes Icon */
  .icon-notes-layer {
    transform-origin: 40px 122px; /* Bottom left corner of the document path */
    transition: transform 600ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity var(--dur) var(--ease-soft), filter var(--dur) var(--ease-soft);
  }
  .icon-notes-layer--1 {
    transform: translate(2px, -2px) rotate(2deg);
    opacity: 0.6;
  }
  .icon-notes-layer--2 {
    transform: translate(4px, -4px) rotate(4deg);
    opacity: 0.3;
  }
  .icon-notes-layer--main {
    transition: transform 600ms cubic-bezier(0.34, 1.56, 0.64, 1), filter var(--dur) var(--ease-soft);
  }

  .card:hover .icon-notes-layer--1 {
    transform: translate(8px, -10px) rotate(6deg) scale(1.02);
    opacity: 0.85;
    filter: drop-shadow(-2px 2px 0px rgba(190,210,255,0.3));
  }
  .card:hover .icon-notes-layer--2 {
    transform: translate(18px, -22px) rotate(12deg) scale(1.05);
    opacity: 0.65;
    filter: drop-shadow(-4px 4px 0px rgba(190,210,255,0.2));
  }
  .card:hover .icon-notes-layer--main {
    transform: scale(1.02) translate(-2px, 2px);
    filter: drop-shadow(0 0 8px rgba(190,210,255,0.6));
  }

  /* Tech Icon Animations */
  .icon-tech-core {
    transform-origin: 120px 70px;
    transition: transform 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .card:hover .icon-tech-core {
    transform: scale(1.8) rotate(360deg);
    filter: drop-shadow(0 0 15px var(--beam-cool));
  }
  .icon-tech-traces {
    transition: opacity 200ms ease;
  }
  .card:hover .icon-tech-traces {
    opacity: 1;
    animation: techPulse 0.6s ease-in-out infinite alternate;
  }
  @keyframes techPulse {
    0% { filter: drop-shadow(0 0 4px var(--beam-cool)); opacity: 0.7; stroke-width: 0.5; }
    100% { filter: drop-shadow(0 0 12px var(--beam-cool)); opacity: 1; stroke-width: 1; }
  }

  /* Travel Icon Animations */
  .icon-travel-ring-1, .icon-travel-ring-2, .icon-travel-ring-3 {
    transform-origin: 120px 70px;
    transition: transform 1000ms cubic-bezier(0.16, 1, 0.3, 1), stroke 400ms ease, filter 400ms ease;
  }
  .card:hover .icon-travel-ring-1 { 
    transform: rotate(360deg) scale(1.35); 
    stroke: #0ff; 
    filter: drop-shadow(0 0 10px #0ff); 
  }
  .card:hover .icon-travel-ring-2 { 
    transform: rotate(-720deg) scale(0.65); 
    stroke: #f0f; 
    filter: drop-shadow(0 0 10px #f0f); 
  }
  .card:hover .icon-travel-ring-3 { 
    transform: rotate(540deg) scale(1.6); 
    stroke: #fff; 
    filter: drop-shadow(0 0 15px #fff); 
  }

  .card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--r-pill);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: var(--text);
    background: rgba(255, 255, 255, 0.02);
    transition:
      border-color var(--dur) var(--ease-soft),
      background-color var(--dur) var(--ease-soft),
      box-shadow var(--dur) var(--ease-soft),
      transform 400ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .card__cta .arrow {
    display: inline-block;
    transition: transform var(--dur) var(--ease-soft);
  }
  .card:hover .card__cta {
    border-color: var(--border-bright);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 6px 24px -8px rgba(190, 210, 255, 0.35);
    transform: translateX(10px) !important;
  }
  .card:hover .card__cta .arrow { transform: translate(2px, -2px); }

  .card__particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 4;
    overflow: hidden;
  }
  .card__particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: var(--beam-cool);
    border-radius: 50%;
    left: 50%;
    bottom: -10px;
    opacity: 0;
    box-shadow: 0 0 10px var(--beam-cool);
  }
  .card:hover .card__particle {
    animation: cardParticleUp 1.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    animation-delay: calc(var(--pi) * 0.15s);
  }

  @keyframes cardParticleUp {
    0% { transform: translate(-50%, 0) scale(1); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 0.8; }
    100% { transform: translate(calc(-50% + (var(--pi) * 15px - 30px)), -120px) scale(0); opacity: 0; }
  }

  @media (max-width: 640px) {
    .card { transform: none !important; min-height: 300px; padding: 1.3rem 1.2rem 1.2rem; }
    .card__title { font-size: 1.35rem; }
  }
</style>

<script>
  function tilt(card: HTMLElement, max = 15) {
    const stage = card.parentElement;
    if (!stage) return;
    let raf = 0;
    let nx = 0, ny = 0;          // current normalised cursor (-1..1)
    let cx = 0, cy = 0;          // smoothed
    let rect: DOMRect | null = null;

    const apply = () => {
      cx += (nx - cx) * 0.12;
      cy += (ny - cy) * 0.12;
      const rx = (cy *  max).toFixed(2);
      const ry = (cx * -max).toFixed(2);
      card.style.setProperty('--rx', `${rx}deg`);
      card.style.setProperty('--ry', `${ry}deg`);
      // also update spotlight + shine in pixel space using the live rect
      if (rect) {
        const px = ((nx + 1) * 0.5) * rect.width;
        const py = ((ny + 1) * 0.5) * rect.height;
        card.style.setProperty('--mx', `${px}px`);
        card.style.setProperty('--my', `${py}px`);
      }
      if (Math.abs(nx - cx) + Math.abs(ny - cy) > 0.001) {
        raf = requestAnimationFrame(apply);
      } else {
        raf = 0;
      }
    };

    const onMove = (e: MouseEvent) => {
      rect = card.getBoundingClientRect();
      nx = ((e.clientX - rect.left) / rect.width)  * 2 - 1;
      ny = ((e.clientY - rect.top)  / rect.height) * 2 - 1;
      if (!raf) raf = requestAnimationFrame(apply);
    };
    const onLeave = () => {
      nx = 0; ny = 0;
      if (!raf) raf = requestAnimationFrame(apply);
    };

    card.addEventListener('mousemove', onMove);
    card.addEventListener('mouseleave', onLeave);
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.card-stage > .card').forEach((c) => {
      if ((c as any).__tilt) return;
      (c as any).__tilt = true;
      tilt(c);
    });
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
