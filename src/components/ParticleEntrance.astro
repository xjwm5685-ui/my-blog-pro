---
/**
 * ParticleEntrance v2 — five-act cinematic arrival.
 *
 *   Act 0 · BOOT       (0.0–1.2s)  pure black + typed system boot HUD +
 *                                  loading bar filling on bottom edge
 *   Act 1 · WARP       (1.2–2.8s)  radial light streaks accelerate toward
 *                                  center (hyperspace approach), bar fills
 *                                  to 100% with a thump
 *   Act 2 · IMPACT     (2.8–3.2s)  HARD CUT — full-white flash, camera
 *                                  shake, lines explode, HUD flickers
 *   Act 3 · MATERIALIZE(3.2–4.8s)  800 particles burst from a SINGULAR
 *                                  center point spiraling outward to form
 *                                  WYHEF letter pixels
 *   Act 4 · LOCK-IN    (4.8–5.4s)  letters snap, chromatic aberration
 *                                  spike, second flash, subtitle types in
 *   Act 5 · REVEAL     (5.4–6.5s)  particles disperse to bg star field,
 *                                  hero materializes layer by layer
 *
 * Gates on sessionStorage.wyhef_entered. Mobile + reduced-motion skip
 * to a quick fade. Pure canvas + DOM, no dependencies.
 */
import { SITE_CONFIG } from '@/config';
const wordmark = SITE_CONFIG.wordmark;
const subtitle = SITE_CONFIG.subtitle;
---

<script is:inline define:vars={{ wordmark }}>
  (function() {
    if (sessionStorage.getItem('wyhef_entered') === '1') return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      sessionStorage.setItem('wyhef_entered', '1');
      return;
    }
    document.body.classList.add('entrance-needed');
  })();
</script>

<div class="pe" data-pe data-wordmark={wordmark} data-subtitle={subtitle} aria-hidden="true">
  <div class="pe__shake" data-pe-shake>
    <canvas class="pe__canvas" data-pe-canvas></canvas>

    <div class="pe__chrom pe__chrom--r" data-pe-chrom-r></div>
    <div class="pe__chrom pe__chrom--b" data-pe-chrom-b></div>
    <span class="pe__flash" data-pe-flash></span>
  </div>

  <!-- HUD — sits above the shake layer so flash hits look layered -->
  <div class="pe__hud pe__hud--tl">
    <span class="pe__dot pe__dot--green"></span>
    <span class="pe__hud-text" data-pe-boot>BOOTING ·</span>
  </div>

  <div class="pe__hud pe__hud--tr">
    <span class="pe__hud-mono">STREAM · 0001 ·</span>
    <span class="pe__hud-mono pe__hud-mono--bright" data-pe-freq>87.3 MHz</span>
    <span class="pe__hud-mono">·</span>
    <span class="pe__dot pe__dot--red"></span>
    <span class="pe__hud-mono pe__hud-mono--bright">LIVE</span>
  </div>

  <div class="pe__hud pe__hud--bl">
    <span class="pe__hud-mono pe__hud-mono--small" data-pe-trace>TRACE · 0x000000</span>
  </div>

  <div class="pe__hud pe__hud--br">
    <span class="pe__hud-mono pe__hud-mono--small" data-pe-clock>00:00:00.000</span>
  </div>

  <div class="pe__bar">
    <span class="pe__bar-fill" data-pe-bar-fill></span>
    <span class="pe__bar-label" data-pe-bar-label>LOADING · 00%</span>
  </div>

  <div class="pe__title" data-pe-title>
    <span class="pe__title-bracket">[</span>
    <span class="pe__title-text" data-pe-title-text>INITIATING WYHEF</span>
    <span class="pe__title-bracket">]</span>
  </div>

  <div class="pe__sub" data-pe-sub></div>
</div>

<style>
  .pe {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: none;
    background: #000;
    display: none;
    overflow: hidden;
  }
  :global(body.entrance-needed) .pe { display: block; }
  :global(body.entrance-fading)  .pe { opacity: 0; transition: opacity 700ms ease; }

  .pe__shake {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  .pe__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Chromatic-aberration layers — the canvas is mirrored into red and blue
     siblings, slightly offset, mix-blend-mode: screen. JS animates the
     offset (--cx, --cy) for the chromatic spike during lock-in. */
  .pe__chrom {
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0;
    will-change: transform, opacity;
  }
  .pe__chrom--r { background-image: var(--chrom-img); transform: translate(calc(var(--cx, 0px) * -1), calc(var(--cy, 0px) * -1)); filter: hue-rotate(0deg) saturate(2); }
  .pe__chrom--b { background-image: var(--chrom-img); transform: translate(var(--cx, 0px), var(--cy, 0px)); filter: hue-rotate(180deg) saturate(2); }

  .pe__flash {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center,
      rgba(255, 255, 255, 1) 0%,
      rgba(190, 210, 255, 0.85) 40%,
      transparent 70%);
    opacity: 0;
    pointer-events: none;
    will-change: opacity;
  }

  /* HUD chips — typed bootlog, ticker, trace, clock */
  .pe__hud {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-soft);
    opacity: 0;
    animation: peHudIn 800ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .pe__hud--tl { top: 1.4rem;  left: 1.4rem;  animation-delay: 260ms; }
  .pe__hud--tr { top: 1.4rem;  right: 1.4rem; animation-delay: 360ms; }
  .pe__hud--bl { left: 1.4rem; bottom: 4rem;  animation-delay: 460ms; }
  .pe__hud--br { right: 1.4rem; bottom: 4rem; animation-delay: 560ms; }
  @keyframes peHudIn {
    from { opacity: 0; transform: translateY(6px); filter: blur(4px); }
    to   { opacity: 1; transform: translateY(0);   filter: blur(0); }
  }

  /* Bootlog text crossfade — text swaps fade through opacity */
  .pe__hud-text {
    display: inline-block;
    transition: opacity 240ms ease;
  }
  .pe__hud-text.is-fading { opacity: 0; }

  .pe__hud-mono { color: var(--text-soft); }
  .pe__hud-mono--bright { color: var(--text); font-weight: 500; }
  .pe__hud-mono--small  { font-size: 0.6rem; letter-spacing: 0.22em; color: var(--text-muted); }

  .pe__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
  }
  .pe__dot--green {
    background: #6ee7a8;
    box-shadow: 0 0 8px rgba(110, 231, 168, 0.85);
    animation: peDotPulse 1.4s ease-in-out infinite;
  }
  .pe__dot--red {
    background: #ff5d6e;
    box-shadow: 0 0 8px rgba(255, 93, 110, 0.85);
    animation: peDotPulse 0.9s ease-in-out infinite;
  }
  @keyframes peDotPulse {
    0%, 100% { opacity: 0.45; transform: scale(0.85); }
    50%      { opacity: 1; transform: scale(1.15); }
  }

  /* Bottom loading bar — sits at the very bottom edge */
  .pe__bar {
    position: absolute;
    left: 1.4rem; right: 1.4rem;
    bottom: 1.4rem;
    height: 26px;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    opacity: 0;
    animation: peHudIn 800ms cubic-bezier(0.22, 1, 0.36, 1) 360ms forwards;
  }
  .pe__bar::before {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    position: relative;
  }
  .pe__bar-fill {
    position: absolute;
    left: 1.4rem;
    bottom: calc(1.4rem + 12px);
    height: 1px;
    width: 0;
    background: linear-gradient(90deg,
      rgba(190, 210, 255, 0.85),
      rgba(255, 255, 255, 1));
    box-shadow:
      0 0 12px rgba(190, 210, 255, 0.85),
      0 0 24px rgba(190, 210, 255, 0.45);
    will-change: width;
  }
  .pe__bar-label {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.32em;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  /* Center marquee title */
  .pe__title {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0;
    filter: blur(8px);
    animation: peTitleIn 1100ms cubic-bezier(0.22, 1, 0.36, 1) 700ms forwards;
    z-index: 4;
    will-change: opacity, transform, filter;
  }
  .pe__title-bracket { color: var(--text-muted); }
  @keyframes peTitleIn {
    0%   { opacity: 0; transform: translate(-50%, -50%) scale(0.92); filter: blur(10px); letter-spacing: 0.6em; }
    60%  { opacity: 1; }
    100% { opacity: 1; transform: translate(-50%, -50%) scale(1);    filter: blur(0);    letter-spacing: 0.32em; }
  }
  .pe.is-titlegone .pe__title {
    animation: peTitleOut 700ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes peTitleOut {
    0%   { opacity: 1; filter: blur(0);    letter-spacing: 0.32em; }
    100% { opacity: 0; filter: blur(10px); letter-spacing: 0.7em; }
  }

  /* Subtitle (CN tagline) — chars fade in individually */
  .pe__sub {
    position: absolute;
    top: calc(50% + 100px);
    left: 50%;
    transform: translate(-50%, 0);
    font-family: var(--font-cn);
    font-size: 1rem;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    z-index: 4;
    white-space: nowrap;
    text-shadow: 0 0 12px rgba(190, 210, 255, 0.45);
  }
  .pe__sub-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    filter: blur(6px);
    transition:
      opacity 520ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 520ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pe__sub-char.is-in {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  /* While entrance is needed, hide the live hero AND the global HUD chips
     so the canvas is alone on stage.
     Initial state has blur + slight scale-down — used as the "from" of
     the reveal transition (instead of just opacity 0→1) so text
     materializes through fog instead of snapping in. */
  :global(body.entrance-needed) :global(.wordmark) {
    opacity: 1 !important; /* wordmark itself stays "visible" — letters do the work */
    visibility: visible;
    transition: none !important;
  }
  :global(body.entrance-needed) :global(.wordmark__letter) {
    opacity: 0 !important;
    transform: translateY(0.4em);
    filter: blur(24px);
    animation: none !important;
    transition: none !important;
  }
  :global(body.entrance-needed) :global(.hero__subtitle),
  :global(body.entrance-needed) :global(.hero__search),
  :global(body.entrance-needed) :global(.hero__top),
  :global(body.entrance-needed) :global(.hero__bottom),
  :global(body.entrance-needed) :global(.hero__halo) {
    opacity: 0 !important;
    visibility: hidden;
    filter: blur(20px);
    transform: scale(0.96);
    transition: none !important;
  }
  :global(body.entrance-needed) :global(.hud),
  :global(body.entrance-needed) :global(.ga),
  :global(body.entrance-needed) :global(.si),
  :global(body.entrance-needed) :global(.nr),
  :global(body.entrance-needed) :global(.spot-hint),
  :global(body.entrance-needed) :global(.sp),
  :global(body.entrance-needed) :global(.cur) {
    opacity: 0 !important;
    visibility: hidden !important;
    transition: none !important;
  }

  /* Reveal — wordmark letters cascade independently with blur+translate */
  :global(body.entrance-revealing) :global(.wordmark__letter) {
    opacity: 1 !important;
    transform: translateY(0);
    filter: blur(0);
    transition:
      opacity   1500ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 1500ms cubic-bezier(0.16, 1, 0.3, 1),
      filter    1500ms cubic-bezier(0.16, 1, 0.3, 1) !important;
  }
  :global(body.entrance-revealing) :global(.wordmark__letter:nth-child(1)) { transition-delay: 0ms;   }
  :global(body.entrance-revealing) :global(.wordmark__letter:nth-child(2)) { transition-delay: 130ms; }
  :global(body.entrance-revealing) :global(.wordmark__letter:nth-child(3)) { transition-delay: 260ms; }
  :global(body.entrance-revealing) :global(.wordmark__letter:nth-child(4)) { transition-delay: 390ms; }
  :global(body.entrance-revealing) :global(.wordmark__letter:nth-child(5)) { transition-delay: 520ms; }
  :global(body.entrance-revealing) :global(.wordmark__letter:nth-child(6)) { transition-delay: 650ms; }

  :global(body.entrance-revealing) :global(.hero__halo) {
    opacity: 1 !important;
    visibility: visible;
    filter: blur(40px);
    transform: scale(1);
    transition:
      opacity   1500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms,
      filter    1500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms,
      transform 1500ms cubic-bezier(0.16, 1, 0.3, 1) 200ms !important;
  }
  :global(body.entrance-revealing) :global(.hero__subtitle) {
    opacity: 1 !important;
    visibility: visible;
    filter: blur(0);
    transform: scale(1) translateY(0);
    transition:
      opacity   1500ms cubic-bezier(0.16, 1, 0.3, 1) 800ms,
      filter    1500ms cubic-bezier(0.16, 1, 0.3, 1) 800ms,
      transform 1500ms cubic-bezier(0.16, 1, 0.3, 1) 800ms !important;
  }
  :global(body.entrance-revealing) :global(.hero__search) {
    opacity: 1 !important;
    visibility: visible;
    filter: blur(0);
    transform: scale(1);
    transition:
      opacity   1500ms cubic-bezier(0.16, 1, 0.3, 1) 1100ms,
      filter    1500ms cubic-bezier(0.16, 1, 0.3, 1) 1100ms,
      transform 1500ms cubic-bezier(0.16, 1, 0.3, 1) 1100ms !important;
  }
  :global(body.entrance-revealing) :global(.hero__top),
  :global(body.entrance-revealing) :global(.hero__bottom) {
    opacity: 1 !important;
    visibility: visible;
    filter: blur(0);
    transform: scale(1);
    transition:
      opacity   1300ms cubic-bezier(0.16, 1, 0.3, 1) 1400ms,
      filter    1300ms cubic-bezier(0.16, 1, 0.3, 1) 1400ms,
      transform 1300ms cubic-bezier(0.16, 1, 0.3, 1) 1400ms !important;
  }

  /* Global HUD chips — soft re-appear after hero is in */
  :global(body.entrance-revealing) :global(.hud),
  :global(body.entrance-revealing) :global(.ga),
  :global(body.entrance-revealing) :global(.si),
  :global(body.entrance-revealing) :global(.nr),
  :global(body.entrance-revealing) :global(.sp) {
    opacity: 1 !important;
    visibility: visible;
    transition: opacity 1100ms cubic-bezier(0.16, 1, 0.3, 1) 1700ms !important;
  }
  :global(body.entrance-revealing) :global(.cur) {
    opacity: 1 !important;
    visibility: visible;
    transition: opacity 600ms ease 1900ms !important;
  }

  /* Mobile: skip canvas, simple fade */
  @media (max-width: 720px) {
    .pe__canvas, .pe__chrom, .pe__bar, .pe__sub { display: none; }
    .pe__hud--bl, .pe__hud--br { display: none; }
    .pe__title { font-size: 0.72rem; }
  }
</style>

<script>
  type Particle = {
    /* burst origin (center singularity, with slight jitter) */
    sx: number; sy: number;
    /* target letter pixel */
    tx: number; ty: number;
    /* current position */
    cx: number; cy: number;
    /* per-particle stagger and travel */
    delay: number;
    travel: number;
    /* spiral parameters */
    spiralA: number;   // base angle
    spiralR: number;   // initial radius
    /* disperse */
    final: number;     // outward angle for disperse
    /* visual */
    hue: 'w' | 'b';
  };

  /* Warp streaks for Act 1 — radial lines accelerating toward center */
  type Streak = {
    a: number;   // angle from center
    rStart: number;
    rEnd: number;
    born: number;   // ms when this streak was emitted
    life: number;   // ms duration
    hue: 'w' | 'b';
  };

  function easeOutCubic(t: number) { return 1 - Math.pow(1 - t, 3); }
  function easeInCubic(t: number)  { return t * t * t; }
  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

  async function bootEntrance() {
    if (!document.body.classList.contains('entrance-needed')) return;
    const root = document.querySelector<HTMLElement>('[data-pe]');
    if (!root) return;

    /* Mobile path: just fade */
    if (window.matchMedia('(max-width: 720px)').matches) {
      window.setTimeout(() => {
        document.body.classList.add('entrance-revealing');
        document.body.classList.add('entrance-fading');
        sessionStorage.setItem('wyhef_entered', '1');
        window.setTimeout(() => {
          document.body.classList.remove('entrance-needed');
          document.body.classList.remove('entrance-fading');
          root.parentNode?.removeChild(root);
        }, 900);
      }, 700);
      return;
    }

    const canvas = root.querySelector<HTMLCanvasElement>('[data-pe-canvas]');
    const flash  = root.querySelector<HTMLElement>('[data-pe-flash]');
    const shake  = root.querySelector<HTMLElement>('[data-pe-shake]');
    const boot   = root.querySelector<HTMLElement>('[data-pe-boot]');
    const trace  = root.querySelector<HTMLElement>('[data-pe-trace]');
    const clockEl= root.querySelector<HTMLElement>('[data-pe-clock]');
    const barFill= root.querySelector<HTMLElement>('[data-pe-bar-fill]');
    const barLbl = root.querySelector<HTMLElement>('[data-pe-bar-label]');
    const subEl  = root.querySelector<HTMLElement>('[data-pe-sub]');
    if (!canvas || !flash || !shake || !boot || !trace || !clockEl || !barFill || !barLbl || !subEl) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    /* Wait for fonts so the offscreen text matches the real wordmark */
    try { await (document as any).fonts?.ready; } catch { /* noop */ }

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = window.innerWidth;
    let h = window.innerHeight;
    canvas.width  = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width  = w + 'px';
    canvas.style.height = h + 'px';
    ctx.scale(dpr, dpr);

    /* sample WYHEF pixel positions */
    const wordmark = root.dataset.wordmark || 'WYHEF';
    const subtitle = root.dataset.subtitle || '';
    const fontSize = Math.min(Math.max(w * 0.18, 80), 280);
    const off = document.createElement('canvas');
    off.width = w; off.height = h;
    const offCtx = off.getContext('2d', { willReadFrequently: true });
    if (!offCtx) return;
    offCtx.fillStyle = '#fff';
    offCtx.font = `200 ${fontSize}px Geist, sans-serif`;
    offCtx.textBaseline = 'middle';
    offCtx.textAlign = 'left';
    const shellPad = Math.max(w * 0.04, 16);
    const cy = h * 0.5;
    offCtx.fillText(wordmark, shellPad, cy);

    const data = offCtx.getImageData(0, 0, w, h).data;
    const samples: [number, number][] = [];
    const stride = 3;
    for (let y = 0; y < h; y += stride) {
      for (let x = 0; x < w; x += stride) {
        if (data[(y * w + x) * 4 + 3] > 80) samples.push([x, y]);
      }
    }
    if (!samples.length) {
      sessionStorage.setItem('wyhef_entered', '1');
      document.body.classList.add('entrance-revealing');
      window.setTimeout(() => {
        document.body.classList.remove('entrance-needed');
        root.parentNode?.removeChild(root);
      }, 900);
      return;
    }

    /* Center singularity = approximate centroid of letters (or screen center) */
    const cxOrigin = w * 0.5;
    const cyOrigin = h * 0.5;

    /* Build particles — each starts at center, ends at letter pixel */
    const N = Math.min(900, samples.length);
    const particles: Particle[] = [];
    for (let i = 0; i < N; i++) {
      const [tx, ty] = samples[Math.floor(Math.random() * samples.length)];
      particles.push({
        sx: cxOrigin + (Math.random() - 0.5) * 60,
        sy: cyOrigin + (Math.random() - 0.5) * 30,
        cx: cxOrigin, cy: cyOrigin,
        tx, ty,
        delay: Math.random() * 0.35,
        travel: 0.7 + Math.random() * 0.7,
        spiralA: Math.random() * Math.PI * 2,
        spiralR: 30 + Math.random() * 80,
        final: Math.random() * Math.PI * 2,
        hue: Math.random() < 0.85 ? 'w' : 'b'
      });
    }

    /* Warp streaks for Act 1 */
    const streaks: Streak[] = [];

    /* Phase clock (ms) */
    const T_BOOT_END   = 1200;
    const T_WARP_END   = 2800;
    const T_IMPACT_END = 3200;
    const T_MAT_END    = 4800;
    const T_LOCK_END   = 5400;
    /* Reveal cascade is long (last letter ends ~7420ms, HUD chips ~8200ms),
       so keep .pe alive until 7600ms so disperse + reveal play in parallel. */
    const T_END        = 7600;

    const t0 = performance.now();
    let raf = 0;
    let revealed = false;
    let dismissed = false;

    /* HUD message script — typed during boot */
    const bootMessages = [
      'BOOTING ·',
      'BOOT · INTEGRITY OK',
      'FRAME LOCK ACQUIRED ·',
      'BEAM ALIGNED · SIGNAL ·',
      'WYHEF ONLINE ·'
    ];
    const traceMessages = [
      'TRACE · 0x000000',
      'TRACE · 0x4F2A8B',
      'TRACE · 0x8C13D7',
      'TRACE · 0xFF7A2C',
      'TRACE · 0x00FF88'
    ];

    let bootIdx = 0;
    let traceIdx = 0;
    /* Boot messages crossfade in/out instead of instant swap */
    const swapBoot = (next: string) => {
      boot.classList.add('is-fading');
      window.setTimeout(() => {
        boot.textContent = next;
        boot.classList.remove('is-fading');
      }, 240);
    };
    const bootTimer = window.setInterval(() => {
      if (bootIdx < bootMessages.length) swapBoot(bootMessages[bootIdx++]);
    }, 480);
    const traceTimer = window.setInterval(() => {
      traceIdx = (traceIdx + 1) % traceMessages.length;
      trace.textContent = traceMessages[traceIdx];
    }, 110);

    /* Tick a millisecond clock from t0 */
    const fmt2 = (n: number) => n.toString().padStart(2, '0');
    const fmt3 = (n: number) => n.toString().padStart(3, '0');
    const clockTimer = window.setInterval(() => {
      const e = performance.now() - t0;
      clockEl.textContent =
        `${fmt2(Math.floor(e / 60000))}:${fmt2(Math.floor((e % 60000) / 1000))}.${fmt3(Math.floor(e) % 1000)}`;
    }, 33);

    /* Camera shake helper */
    let shakeUntil = 0;
    let shakeMag = 0;
    const triggerShake = (ms: number, mag: number) => {
      shakeUntil = performance.now() + ms;
      shakeMag = mag;
    };

    /* Flash helper — full rise-hold-fall envelope (no jarring snap-to-peak) */
    const triggerFlash = (peak: number, rise: number, hold: number, fall: number) => {
      const total = rise + hold + fall;
      flash.animate([
        { opacity: 0 },
        { opacity: peak, offset: rise / total },
        { opacity: peak, offset: (rise + hold) / total },
        { opacity: 0 }
      ], {
        duration: total,
        easing: 'cubic-bezier(0.33, 0, 0.32, 1)',
        fill: 'forwards'
      });
    };

    function spawnStreak(now: number) {
      const a = Math.random() * Math.PI * 2;
      streaks.push({
        a,
        rStart: Math.max(w, h) * 0.7,
        rEnd: 30,
        born: now,
        life: 600 + Math.random() * 300,
        hue: Math.random() < 0.8 ? 'w' : 'b'
      });
    }

    function draw(now: number) {
      const elapsed = now - t0;

      /* Camera shake */
      if (now < shakeUntil) {
        const sx = (Math.random() - 0.5) * shakeMag;
        const sy = (Math.random() - 0.5) * shakeMag;
        shake!.style.transform = `translate3d(${sx.toFixed(1)}px, ${sy.toFixed(1)}px, 0)`;
      } else {
        shake!.style.transform = 'translate3d(0, 0, 0)';
      }

      /* Persistent ambient bg with trail decay */
      ctx!.fillStyle = 'rgba(0, 0, 0, 0.32)';
      ctx!.fillRect(0, 0, w, h);

      /* Tiny ambient stars */
      ctx!.fillStyle = 'rgba(255, 255, 255, 0.05)';
      for (let i = 0; i < 80; i++) {
        const x = (i * 47.31) % w;
        const y = (i * 73.19) % h;
        ctx!.beginPath();
        ctx!.arc(x, y, 0.7, 0, Math.PI * 2);
        ctx!.fill();
      }

      /* ============== ACT 0 · BOOT (0–1.2s) ============== */
      if (elapsed < T_BOOT_END) {
        /* central pixel growing into a horizontal seam */
        const t = elapsed / T_BOOT_END;
        const seamW = lerp(2, Math.min(w * 0.85, 760), easeOutCubic(t));
        const seamH = lerp(2, 2, t);
        ctx!.fillStyle = `rgba(255, 255, 255, ${(0.4 + t * 0.55).toFixed(3)})`;
        ctx!.fillRect((w - seamW) / 2, h / 2 - seamH / 2, seamW, seamH);
        /* halo */
        ctx!.shadowBlur = 24;
        ctx!.shadowColor = 'rgba(190, 210, 255, 0.85)';
        ctx!.fillRect((w - seamW) / 2, h / 2 - seamH / 2, seamW, seamH);
        ctx!.shadowBlur = 0;

        const pct = Math.floor(t * 38);
        barFill!.style.width = (pct * 0.95) + '%';
        barLbl!.textContent = `LOADING · ${pct.toString().padStart(2, '0')}%`;
      }

      /* ============== ACT 1 · WARP (1.2–2.8s) ============== */
      else if (elapsed < T_WARP_END) {
        const t = (elapsed - T_BOOT_END) / (T_WARP_END - T_BOOT_END);
        const ec = easeInCubic(t);

        /* Spawn a few new streaks per frame, ramping up */
        const spawnRate = Math.floor(2 + ec * 14);
        for (let i = 0; i < spawnRate; i++) spawnStreak(now);

        /* Draw active streaks */
        for (let i = streaks.length - 1; i >= 0; i--) {
          const s = streaks[i];
          const age = (now - s.born) / s.life;
          if (age >= 1) { streaks.splice(i, 1); continue; }
          const ee = easeInCubic(age);
          const r = lerp(s.rStart, s.rEnd, ee);
          const x = w / 2 + Math.cos(s.a) * r;
          const y = h / 2 + Math.sin(s.a) * r;
          const tailLen = 80 + ee * 240;
          const x2 = w / 2 + Math.cos(s.a) * (r + tailLen);
          const y2 = h / 2 + Math.sin(s.a) * (r + tailLen);
          const grad = ctx!.createLinearGradient(x2, y2, x, y);
          grad.addColorStop(0, 'rgba(255, 255, 255, 0)');
          if (s.hue === 'w') {
            grad.addColorStop(0.6, `rgba(255, 255, 255, ${(0.6 * (1 - age)).toFixed(3)})`);
            grad.addColorStop(1,   `rgba(255, 255, 255, ${(1 - age).toFixed(3)})`);
          } else {
            grad.addColorStop(0.6, `rgba(190, 210, 255, ${(0.6 * (1 - age)).toFixed(3)})`);
            grad.addColorStop(1,   `rgba(190, 210, 255, ${(1 - age).toFixed(3)})`);
          }
          ctx!.strokeStyle = grad;
          ctx!.lineWidth = 1.4;
          ctx!.beginPath();
          ctx!.moveTo(x2, y2);
          ctx!.lineTo(x, y);
          ctx!.stroke();
        }

        /* central seam glows brighter and stretches vertically */
        const seamW = Math.min(w * 0.92, 900);
        const seamH = lerp(2, 28 + ec * 60, t);
        ctx!.fillStyle = `rgba(255, 255, 255, ${(0.6 + ec * 0.35).toFixed(3)})`;
        ctx!.fillRect((w - seamW) / 2, (h - seamH) / 2, seamW, seamH);

        const pct = Math.floor(38 + t * 60);
        barFill!.style.width = pct + '%';
        barLbl!.textContent = `LOADING · ${pct.toString().padStart(2, '0')}%`;
      }

      /* ============== ACT 2 · IMPACT (2.8–3.2s) ============== */
      else if (elapsed < T_IMPACT_END) {
        const t = (elapsed - T_WARP_END) / (T_IMPACT_END - T_WARP_END);
        if (t < 0.05 && !(root as any).__flashed1) {
          (root as any).__flashed1 = true;
          /* impact flash: slow rise, brief hold, long fade */
          triggerFlash(1.0, 260, 80, 520);
          triggerShake(420, 20);
          /* hide the title — now the canvas takes over */
          root.classList.add('is-titlegone');
          barFill!.style.width = '100%';
          barLbl!.textContent  = 'LOADING · 100%';
        }

        /* Streaks scatter outward (briefly drawn as the warp continues collapsing) */
        for (let i = streaks.length - 1; i >= 0; i--) {
          const s = streaks[i];
          const age = Math.min(1, (now - s.born) / s.life);
          if (age >= 1) { streaks.splice(i, 1); continue; }
          const r = lerp(s.rStart, s.rEnd, age);
          const x = w / 2 + Math.cos(s.a) * r;
          const y = h / 2 + Math.sin(s.a) * r;
          ctx!.fillStyle = `rgba(255, 255, 255, ${(1 - age).toFixed(3)})`;
          ctx!.beginPath();
          ctx!.arc(x, y, 1.4, 0, Math.PI * 2);
          ctx!.fill();
        }
      }

      /* ============== ACT 3 · MATERIALIZE (3.2–4.8s) ============== */
      else if (elapsed < T_MAT_END) {
        const t = (elapsed - T_IMPACT_END) / (T_MAT_END - T_IMPACT_END);
        for (const p of particles) {
          const local = (t - p.delay) / Math.max(0.1, p.travel * 0.8);
          if (local < 0) continue;
          const e = easeOutCubic(Math.min(1, local));

          /* spiral component — radius decreases with progress */
          const angle = p.spiralA + e * 4.2;
          const rad   = (1 - e) * p.spiralR;

          /* base interpolation from origin to target */
          const baseX = lerp(p.sx, p.tx, e);
          const baseY = lerp(p.sy, p.ty, e);
          p.cx = baseX + Math.cos(angle) * rad;
          p.cy = baseY + Math.sin(angle) * rad;

          const a = (0.85 * Math.min(1, local + 0.2)).toFixed(3);
          ctx!.fillStyle = p.hue === 'w'
            ? `rgba(255, 255, 255, ${a})`
            : `rgba(190, 210, 255, ${a})`;
          ctx!.beginPath();
          ctx!.arc(p.cx, p.cy, 1.3, 0, Math.PI * 2);
          ctx!.fill();
        }
      }

      /* ============== ACT 4 · LOCK-IN (4.8–5.4s) ============== */
      else if (elapsed < T_LOCK_END) {
        const t = (elapsed - T_MAT_END) / (T_LOCK_END - T_MAT_END);
        if (!(root as any).__flashed2) {
          (root as any).__flashed2 = true;
          /* lock-in flash: even softer rise, short hold, long fade */
          triggerFlash(0.85, 320, 100, 520);
          triggerShake(380, 14);
          /* subtitle: render as per-char spans, stagger fade-in */
          if (subtitle) {
            const chars = Array.from(subtitle);
            subEl.innerHTML = '';
            const spans: HTMLSpanElement[] = chars.map((ch) => {
              const s = document.createElement('span');
              s.className = 'pe__sub-char';
              s.textContent = ch === ' ' ? ' ' : ch;
              subEl.appendChild(s);
              return s;
            });
            spans.forEach((s, i) => {
              window.setTimeout(() => s.classList.add('is-in'), i * 55);
            });
          }
        }

        for (const p of particles) {
          p.cx = p.tx;
          p.cy = p.ty;
          const r = 1.6 - t * 0.6;
          const a = (1 - t * 0.4).toFixed(3);
          ctx!.fillStyle = p.hue === 'w'
            ? `rgba(255, 255, 255, ${a})`
            : `rgba(190, 210, 255, ${a})`;
          ctx!.beginPath();
          ctx!.arc(p.cx, p.cy, r, 0, Math.PI * 2);
          ctx!.fill();
        }
      }

      /* ============== ACT 5 · DISPERSE + REVEAL (5.4–6.5s) ============== */
      else if (elapsed < T_END) {
        const t = (elapsed - T_LOCK_END) / (T_END - T_LOCK_END);
        const ee = easeOutCubic(t);
        const dist = ee * 800;

        for (const p of particles) {
          p.cx = p.tx + Math.cos(p.final) * dist;
          p.cy = p.ty + Math.sin(p.final) * dist;
          const a = ((1 - t) * 0.85).toFixed(3);
          ctx!.fillStyle = p.hue === 'w'
            ? `rgba(255, 255, 255, ${a})`
            : `rgba(190, 210, 255, ${a})`;
          ctx!.beginPath();
          ctx!.arc(p.cx, p.cy, 1.0, 0, Math.PI * 2);
          ctx!.fill();
        }

        if (!revealed) {
          revealed = true;
          document.body.classList.add('entrance-revealing');
        }
      }

      /* End: dismount */
      if (!dismissed && elapsed >= T_END) {
        dismissed = true;
        sessionStorage.setItem('wyhef_entered', '1');
        document.body.classList.add('entrance-fading');
        window.clearInterval(bootTimer);
        window.clearInterval(traceTimer);
        window.clearInterval(clockTimer);
        window.setTimeout(() => {
          document.body.classList.remove('entrance-needed');
          document.body.classList.remove('entrance-fading');
          root.parentNode?.removeChild(root);
          cancelAnimationFrame(raf);
        }, 700);
      }

      if (!dismissed) raf = requestAnimationFrame(draw);
    }

    raf = requestAnimationFrame(draw);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootEntrance);
  } else {
    bootEntrance();
  }
</script>
