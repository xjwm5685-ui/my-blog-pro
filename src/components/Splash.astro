---
/**
 * Splash — first-paint overlay. Black plate with [LOADING] mono text
 * and a horizontal beam that wipes upward to reveal the page.
 */
---
<div class="splash" data-splash aria-hidden="true">
  <div class="splash__panel">
    <span class="splash__brackets" data-splash-text>[ INITIALISING WYHEF ]</span>
    <span class="splash__beam"></span>
    <span class="splash__hud">
      <span>FIELD · 0001</span>
      <span class="splash__sep"></span>
      <span data-splash-counter>00 %</span>
    </span>
  </div>
</div>

<style>
  .splash {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: all;
    transition: transform 700ms cubic-bezier(0.86, 0, 0.07, 1), opacity 350ms ease 350ms;
    will-change: transform, opacity;
  }
  .splash.is-done {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
  }

  .splash__panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    color: var(--text-soft);
  }

  .splash__brackets {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text);
    overflow: hidden;
    white-space: nowrap;
    border-right: 1px solid var(--text);
    animation: typeCaret 800ms steps(40) forwards;
  }
  @keyframes typeCaret {
    from { width: 0;     border-right-color: var(--text); }
    to   { width: 22ch;  border-right-color: transparent; }
  }

  .splash__beam {
    width: 220px;
    height: 1px;
    background: linear-gradient(90deg,
      transparent,
      rgba(255, 255, 255, 0.85) 50%,
      transparent);
    position: relative;
    overflow: hidden;
  }
  .splash__beam::before {
    content: '';
    position: absolute;
    top: -1px; left: -40px;
    width: 80px; height: 3px;
    background: linear-gradient(90deg,
      transparent,
      rgba(190, 210, 255, 1) 50%,
      transparent);
    box-shadow: 0 0 24px rgba(190, 210, 255, 0.7);
    animation: splashBeam 1500ms ease-in-out infinite;
  }
  @keyframes splashBeam {
    0%   { transform: translateX(0); }
    100% { transform: translateX(260px); }
  }

  .splash__hud {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .splash__sep {
    width: 24px;
    height: 1px;
    background: var(--text-faint);
  }
</style>

<script>
  function bootSplash() {
    const root = document.querySelector<HTMLElement>('[data-splash]');
    if (!root) return;
    const counter = root.querySelector<HTMLElement>('[data-splash-counter]');
    if (sessionStorage.getItem('wyhef_splash_seen')) {
      root.classList.add('is-done');
      setTimeout(() => root.remove(), 800);
      return;
    }

    let p = 0;
    const id = window.setInterval(() => {
      p = Math.min(100, p + Math.round(8 + Math.random() * 18));
      if (counter) counter.textContent = p.toString().padStart(2, '0') + ' %';
      if (p >= 100) {
        window.clearInterval(id);
        setTimeout(() => {
          root.classList.add('is-done');
          sessionStorage.setItem('wyhef_splash_seen', '1');
          setTimeout(() => root.remove(), 800);
        }, 220);
      }
    }, 90);
  }
  bootSplash();
</script>
