---
/**
 * Constellation — true-3D radial star field with cursor-driven yaw/pitch.
 *
 * Each star carries (x, y, z) — projected through a fake camera with focal-
 * length f. A slow auto-spin and the cursor's normalised offset tilt the
 * entire field, so the viewer feels they are looking through space.
 *
 * Props mirror the previous shape so existing call sites don't change.
 */
interface Props {
  density?: number;
  height?: string;
  leftCaption?: string;
  rightCaption?: string;
  minimal?: boolean;
  id?: string;
}
const {
  density = 110,
  height = '64vh',
  leftCaption,
  rightCaption,
  minimal = false,
  id = `constellation-${Math.random().toString(36).slice(2, 9)}`
} = Astro.props;
---

<section class="constellation" style={`--const-h: ${height};`} data-density={density} id={id}>
  <canvas class="constellation__canvas" aria-hidden="true"></canvas>

  <span class="constellation__hint" aria-hidden="true">
    <span class="bracket-label">CURSOR · STEERS THE FIELD</span>
  </span>

  {!minimal && (leftCaption || rightCaption) && (
    <div class="constellation__captions">
      {leftCaption  && <span class="caption caption--left"  data-reveal>{leftCaption}</span>}
      {rightCaption && <span class="caption caption--right" data-reveal style="--reveal-delay: 220ms">{rightCaption}</span>}
    </div>
  )}
</section>

<style>
  .constellation {
    position: relative;
    width: 100%;
    height: var(--const-h);
    overflow: hidden;
    isolation: isolate;
    perspective: 1200px;
  }

  .constellation__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    cursor: grab;
  }
  .constellation__canvas:active { cursor: grabbing; }

  .constellation__hint {
    position: absolute;
    bottom: 1.2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-faint);
    pointer-events: none;
    opacity: 0;
    animation: navFadeIn 1500ms var(--ease-out) forwards;
    animation-delay: 1400ms;
  }

  .constellation__captions {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    pointer-events: none;
    z-index: 2;
  }

  .caption {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5.5vw, 4.5rem);
    font-weight: 200;
    color: var(--text);
    letter-spacing: -0.025em;
    line-height: 1;
    text-shadow:
      0 0 40px rgba(190, 210, 255, 0.18),
      0 0 80px rgba(190, 210, 255, 0.06);
  }
  .caption--left  { justify-self: end;   padding-right: clamp(2rem, 8vw, 8rem); }
  .caption--right { justify-self: start; padding-left:  clamp(2rem, 8vw, 8rem); color: var(--text-soft); }

  @media (max-width: 768px) {
    .constellation__captions {
      grid-template-columns: 1fr;
      grid-auto-rows: 1fr 1fr;
    }
    .caption--left, .caption--right {
      justify-self: center;
      padding: 0;
      text-align: center;
      font-size: clamp(1.6rem, 7vw, 2.4rem);
    }
  }
</style>

<script>
  type Star = {
    x: number; y: number; z: number;     // 3D position around origin
    r: number;                           // base radius
    phase: number;
    speed: number;
    bright: boolean;
  };

  type Comet = {
    sx: number; sy: number;              // start screen pos
    vx: number; vy: number;              // pixel velocity per second
    life: number;                        // 0..1
    duration: number;                    // total life seconds
    startedAt: number;
    width: number;
  };

  function bootField(root: HTMLElement) {
    const canvas = root.querySelector('canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const density = Number(root.dataset.density || 110);
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0, cx = 0, cy = 0;
    let stars: Star[] = [];
    let comets: Comet[] = [];
    let raf = 0;
    let running = false;

    // camera: focal length controls how dramatic the perspective is
    const F = 380;

    // current rotation (yaw = around Y, pitch = around X) and target
    let yaw = 0, pitch = 0;
    let yawTarget = 0, pitchTarget = 0;
    // spontaneous slow spin
    let spin = 0;

    const t0 = performance.now();

    function build() {
      const rect = root.getBoundingClientRect();
      w = rect.width; h = rect.height;
      cx = w * 0.5; cy = h * 0.5;
      canvas.width  = Math.max(1, Math.floor(w * dpr));
      canvas.height = Math.max(1, Math.floor(h * dpr));
      canvas.style.width  = w + 'px';
      canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

      // Stars distributed on a slightly flattened sphere shell, with some inner field
      const radius = Math.min(w, h) * 0.46;
      stars = new Array(density).fill(0).map((_, i) => {
        // direction on sphere
        const u = Math.random();
        const v = Math.random();
        const theta = u * Math.PI * 2;
        const phi   = Math.acos(2 * v - 1);
        // shell-biased radius — keeps centre clear, like the reference
        const t = Math.pow(Math.random(), 0.55);
        const rr = (0.25 + t * 0.85) * radius;
        const x = rr * Math.sin(phi) * Math.cos(theta);
        const y = rr * Math.sin(phi) * Math.sin(theta) * 0.78; // slight squash
        const z = rr * Math.cos(phi);
        const bright = i % 11 === 0;
        return {
          x, y, z,
          r: bright ? 2.2 : 0.5 + Math.random() * 1.0,
          phase: Math.random() * Math.PI * 2,
          speed: 0.6 + Math.random() * 1.5,
          bright
        };
      });
    }

    function project(x: number, y: number, z: number) {
      // rotate around Y (yaw) then X (pitch)
      const cy_ = Math.cos(yaw),  sy_ = Math.sin(yaw);
      const cp  = Math.cos(pitch), sp  = Math.sin(pitch);
      // yaw
      const x1 = x * cy_ + z * sy_;
      const z1 = -x * sy_ + z * cy_;
      // pitch
      const y1 = y * cp - z1 * sp;
      const z2 = y * sp + z1 * cp;

      const denom = F + z2;
      const scale = denom > 1 ? F / denom : 8; // clamp blow-up behind camera
      const sx = cx + x1 * scale;
      const sy = cy + y1 * scale;
      return { sx, sy, scale, depth: z2 };
    }

    function draw(now: number) {
      if (!running) return;
      const t = (now - t0) / 1000;

      // ease rotations toward targets
      yaw   += (yawTarget   - yaw)   * 0.06;
      pitch += (pitchTarget - pitch) * 0.06;
      // continuous slow spin
      spin += 0.0008;
      const spinYaw = yaw + Math.sin(spin) * 0.18;
      const spinPitch = pitch + Math.cos(spin * 0.7) * 0.08;
      const oldYaw = yaw, oldPitch = pitch;
      yaw = spinYaw; pitch = spinPitch;

      ctx!.clearRect(0, 0, w, h);

      // central core glow — sits at z ≈ 0, looks like a nebula heart
      const glow = ctx!.createRadialGradient(cx, cy, 0, cx, cy, Math.min(w, h) * 0.35);
      glow.addColorStop(0,   'rgba(190, 210, 255, 0.18)');
      glow.addColorStop(0.4, 'rgba(120, 150, 220, 0.05)');
      glow.addColorStop(1,   'rgba(0,0,0,0)');
      ctx!.fillStyle = glow;
      ctx!.fillRect(0, 0, w, h);

      // sort by depth so closer stars draw on top
      const projected = stars.map((s) => {
        const p = project(s.x, s.y, s.z);
        return { s, p };
      }).sort((a, b) => b.p.depth - a.p.depth);

      // connector lines from origin to a subset, projected through camera
      const center = project(0, 0, 0);
      ctx!.strokeStyle = 'rgba(190, 210, 255, 0.07)';
      ctx!.lineWidth = 0.6;
      for (let i = 0; i < projected.length; i += 9) {
        const { p } = projected[i];
        if (p.scale <= 0) continue;
        ctx!.beginPath();
        ctx!.moveTo(center.sx, center.sy);
        ctx!.lineTo(p.sx, p.sy);
        ctx!.stroke();
      }

      for (const { s, p } of projected) {
        if (p.scale <= 0) continue;
        const tw = 0.45 + 0.55 * (0.5 + 0.5 * Math.sin(t * s.speed + s.phase));
        const depthAlpha = Math.max(0.15, Math.min(1.4, p.scale / 1.0));
        const alpha = (s.bright ? 0.95 : 0.55) * tw * Math.min(1, depthAlpha);
        const size  = s.r * p.scale;

        if (s.bright) {
          // crisp pixel + halo for hero stars
          ctx!.fillStyle = `rgba(225, 235, 255, ${alpha.toFixed(3)})`;
          ctx!.fillRect(p.sx - size, p.sy - size, size * 2, size * 2);
          ctx!.fillStyle = `rgba(180, 205, 255, ${(alpha * 0.22).toFixed(3)})`;
          ctx!.beginPath();
          ctx!.arc(p.sx, p.sy, size * 4.5, 0, Math.PI * 2);
          ctx!.fill();
        } else {
          ctx!.fillStyle = `rgba(255, 255, 255, ${alpha.toFixed(3)})`;
          ctx!.beginPath();
          ctx!.arc(p.sx, p.sy, Math.max(0.2, size), 0, Math.PI * 2);
          ctx!.fill();
        }
      }

      // ----- shooting stars / comets -----
      const nowSec = now / 1000;
      // spawn new comet probabilistically (~1 every 4-7s)
      if (Math.random() < 0.006) spawnComet(nowSec);
      comets = comets.filter((c) => {
        const dt = nowSec - c.startedAt;
        c.life = dt / c.duration;
        if (c.life >= 1) return false;
        const x = c.sx + c.vx * dt;
        const y = c.sy + c.vy * dt;
        // trail length scales with velocity
        const tailLen = Math.hypot(c.vx, c.vy) * 0.18;
        const ang = Math.atan2(c.vy, c.vx);
        const tx = x - Math.cos(ang) * tailLen;
        const ty = y - Math.sin(ang) * tailLen;
        const fade = c.life < 0.15
          ? c.life / 0.15
          : c.life > 0.7
            ? (1 - c.life) / 0.3
            : 1;
        // tail
        const grad = ctx!.createLinearGradient(tx, ty, x, y);
        grad.addColorStop(0,   'rgba(190, 210, 255, 0)');
        grad.addColorStop(0.4, `rgba(190, 210, 255, ${(0.35 * fade).toFixed(3)})`);
        grad.addColorStop(1,   `rgba(255, 255, 255, ${(0.95 * fade).toFixed(3)})`);
        ctx!.strokeStyle = grad;
        ctx!.lineWidth = c.width;
        ctx!.lineCap = 'round';
        ctx!.beginPath();
        ctx!.moveTo(tx, ty);
        ctx!.lineTo(x, y);
        ctx!.stroke();
        // head halo
        ctx!.fillStyle = `rgba(255, 255, 255, ${(0.9 * fade).toFixed(3)})`;
        ctx!.beginPath();
        ctx!.arc(x, y, c.width * 1.2, 0, Math.PI * 2);
        ctx!.fill();
        ctx!.fillStyle = `rgba(190, 210, 255, ${(0.25 * fade).toFixed(3)})`;
        ctx!.beginPath();
        ctx!.arc(x, y, c.width * 5, 0, Math.PI * 2);
        ctx!.fill();
        return true;
      });

      // restore ease state (we temporarily added spin)
      yaw = oldYaw; pitch = oldPitch;

      raf = requestAnimationFrame(draw);
    }

    function spawnComet(nowSec: number) {
      // pick an off-canvas start near the top, head down-ish across
      const fromLeft = Math.random() < 0.5;
      const sx = fromLeft ? -40 : w + 40;
      const sy = Math.random() * h * 0.6;
      const speed = 380 + Math.random() * 360;     // px/sec
      const ang   = (fromLeft ? 0 : Math.PI) + (Math.random() - 0.5) * 0.6;
      const vx = Math.cos(ang) * speed;
      const vy = Math.sin(ang) * speed + (160 + Math.random() * 180);
      const duration = (Math.hypot(w, h) + 200) / Math.hypot(vx, vy);
      comets.push({
        sx, sy, vx, vy,
        life: 0,
        duration,
        startedAt: nowSec,
        width: 1 + Math.random() * 1.4
      });
    }

    function start() { if (!running) { running = true; raf = requestAnimationFrame(draw); } }
    function stop()  { running = false; cancelAnimationFrame(raf); }

    // cursor steers — relative to the canvas
    function onMove(e: MouseEvent) {
      const rect = canvas!.getBoundingClientRect();
      const nx = (e.clientX - rect.left) / rect.width  * 2 - 1;   // -1..1
      const ny = (e.clientY - rect.top)  / rect.height * 2 - 1;
      yawTarget   = nx *  0.55;
      pitchTarget = ny * -0.42;
    }
    function onLeave() {
      yawTarget = 0; pitchTarget = 0;
    }
    function onTouch(e: TouchEvent) {
      const t = e.touches[0]; if (!t) return;
      const rect = canvas!.getBoundingClientRect();
      const nx = (t.clientX - rect.left) / rect.width  * 2 - 1;
      const ny = (t.clientY - rect.top)  / rect.height * 2 - 1;
      yawTarget   = nx *  0.5;
      pitchTarget = ny * -0.4;
    }
    canvas.addEventListener('mousemove', onMove);
    canvas.addEventListener('mouseleave', onLeave);
    canvas.addEventListener('touchmove', onTouch, { passive: true });

    const ro = new ResizeObserver(() => { stop(); build(); start(); });
    ro.observe(root);
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) (e.isIntersecting ? start() : stop());
    }, { threshold: 0.05 });
    io.observe(root);

    build();
    start();

    document.addEventListener('astro:before-swap', () => {
      stop(); ro.disconnect(); io.disconnect();
      canvas.removeEventListener('mousemove', onMove);
      canvas.removeEventListener('mouseleave', onLeave);
      canvas.removeEventListener('touchmove', onTouch);
    }, { once: true });
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.constellation').forEach((el) => {
      if ((el as any).__field) return;
      (el as any).__field = true;
      bootField(el);
    });
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
