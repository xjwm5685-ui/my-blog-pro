---
import { SITE_CONFIG } from '@/config';

const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---

<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__brand" aria-label={SITE_CONFIG.title}>
      <span class="nav__brand-glyph">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="brand-svg">
          <circle cx="12" cy="12" r="10" stroke-dasharray="16 8 4 8" class="brand-svg-ring"/>
          <path d="M12 2 L12 6 M12 18 L12 22 M2 12 L6 12 M18 12 L22 12" stroke-width="1"/>
          <rect x="9" y="9" width="6" height="6" transform="rotate(45 12 12)" fill="currentColor"/>
          <circle cx="12" cy="12" r="2" fill="#000"/>
        </svg>
      </span>
      <span class="nav__brand-text">{SITE_CONFIG.shortTitle}</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      <ul>
        {SITE_CONFIG.navLinks.map((link, i) => (
          <li style={`--i: ${i}`}>
            <a
              href={link.path}
              class:list={['nav__link', { 'is-active': isActive(link.path) }]}
            >
              <span class="nav__link-en">{link.englishName}</span>
              <span class="nav__link-cn">{link.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav__right">
      <a class="pill pill--ghost nav__cta" href={SITE_CONFIG.github} target="_blank" rel="noopener noreferrer">
        GITHUB <span class="arrow">↗</span>
      </a>
    </div>

    <button class="nav__menu" id="nav-menu-btn" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-h);
    z-index: 1000;
    /* Liquid Glass Effect */
    backdrop-filter: blur(28px) saturate(220%);
    -webkit-backdrop-filter: blur(28px) saturate(220%);
    background: linear-gradient(180deg, 
      rgba(15, 15, 15, 0.45) 0%, 
      rgba(15, 15, 15, 0.25) 100%
    );
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 4px 30px rgba(0, 0, 0, 0.3);
    transition: 
      border-color var(--dur) var(--ease-soft), 
      background var(--dur) var(--ease-soft),
      box-shadow var(--dur) var(--ease-soft);
  }

  .nav.is-scrolled {
    border-bottom-color: rgba(255, 255, 255, 0.1);
    background: linear-gradient(180deg, 
      rgba(5, 5, 5, 0.6) 0%, 
      rgba(5, 5, 5, 0.4) 100%
    );
    box-shadow: 
      0 1px 0 rgba(255, 255, 255, 0.08) inset,
      0 8px 40px rgba(0, 0, 0, 0.6);
  }

  .nav__inner {
    height: 100%;
    padding-inline: var(--shell-px);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2rem;
    align-items: center;
  }

  /* Brand */
  .nav__brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--text);
    font-family: var(--font-brand);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: navFadeIn 700ms var(--ease-out) both;
  }
  .nav__brand-glyph {
    display: inline-flex;
    align-items: center;
    color: var(--beam-cool);
    filter: drop-shadow(0 0 6px rgba(190, 210, 255, 0.4));
  }
  .brand-svg-ring {
    transform-origin: 12px 12px;
    animation: spinRing 8s linear infinite;
  }
  @keyframes spinRing {
    to { transform: rotate(360deg); }
  }
  .nav__brand:hover .brand-svg-ring {
    animation-duration: 2s;
  }
  .nav__brand-text {
    color: var(--text-soft);
  }

  /* Center nav list */
  .nav__links { justify-self: center; }
  .nav__links ul {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: clamp(1rem, 2.6vw, 2.4rem);
  }
  .nav__links li {
    animation: navFadeIn 700ms var(--ease-out) both;
    animation-delay: calc(40ms * var(--i));
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: var(--nav-h);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-soft);
  }
  .nav__link-cn { display: none; }

  .nav__link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 18px;
    width: 0;
    height: 1px;
    background: var(--text);
    transform: translateX(-50%);
    transition: width var(--dur) var(--ease-soft);
  }

  .nav__link:hover { color: var(--text); }
  .nav__link:hover::after,
  .nav__link.is-active::after { width: 18px; }
  .nav__link.is-active { color: var(--text); }

  /* Right CTA */
  .nav__right { display: flex; align-items: center; }
  .nav__cta {
    animation: navFadeIn 700ms var(--ease-out) both;
    animation-delay: 240ms;
  }

  /* Mobile toggle (hidden desktop) */
  .nav__menu {
    display: none;
    background: transparent;
    border: 0;
    width: 38px;
    height: 38px;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 8px;
  }
  .nav__menu span {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--text);
    transition: transform var(--dur) var(--ease-soft), opacity var(--dur);
  }
  .nav.is-menu-open .nav__menu span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav.is-menu-open .nav__menu span:nth-child(2) { opacity: 0; }
  .nav.is-menu-open .nav__menu span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* ---- responsive ---- */
  @media (max-width: 1100px) {
    .nav__links ul { gap: 1.1rem; }
    .nav__link { font-size: 0.66rem; letter-spacing: 0.18em; }
  }

  @media (max-width: 880px) {
    .nav__inner { grid-template-columns: auto 1fr auto; }
    .nav__links {
      position: fixed;
      top: var(--nav-h);
      left: 0; right: 0;
      background: rgba(0, 0, 0, 0.96);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      max-height: 0;
      overflow: hidden;
      transition: max-height 360ms var(--ease-soft);
    }
    .nav.is-menu-open .nav__links { max-height: 80vh; }
    .nav__links ul {
      flex-direction: column;
      gap: 0;
      padding: 1.5rem var(--shell-px);
    }
    .nav__link {
      height: auto;
      padding: 1rem 0;
      border-bottom: 1px solid var(--border);
      width: 100%;
      justify-content: space-between;
    }
    .nav__link::after { display: none; }
    .nav__link-cn { display: inline; color: var(--text-muted); font-family: var(--font-cn); letter-spacing: 0.05em; font-size: 0.78rem; }
    .nav__menu { display: flex; }
    .nav__cta { display: none; }
  }
</style>

<script>
  function bootNav() {
    const nav = document.querySelector<HTMLElement>('.nav');
    if (!nav) return;
    
    // Prevent multiple bindings
    if ((nav as any).__bound) return;
    (nav as any).__bound = true;

    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 12);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const btn = document.getElementById('nav-menu-btn');
    btn?.addEventListener('click', () => {
      const open = nav.classList.toggle('is-menu-open');
      btn.setAttribute('aria-expanded', String(open));
    });
    nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      nav.classList.remove('is-menu-open');
      btn?.setAttribute('aria-expanded', 'false');
    }));
    
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }
  bootNav();
  document.addEventListener('astro:page-load', bootNav);
</script>
